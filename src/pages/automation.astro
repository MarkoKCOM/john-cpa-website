---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="CPA Firm Automation - AI Reminders, Document Collection & OCR | HeshbonAI"
  description="Automate your accounting firm: WhatsApp reminders, document collection, OCR for invoices and receipts, and AI-powered classification. Built for CPA firms worldwide."
  breadcrumbs={[
    { name: "Home", url: "https://heshbonai.co/" },
    { name: "Automation", url: "https://heshbonai.co/automation/" }
  ]}
>
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 bg-navy">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="section-label mb-4">Automation for CPA Firms</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white leading-tight">
          CPA firm automation — less chasing, more accounting
        </h1>
        <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-10">
          Stop doing repetitive manual work. HeshbonAI handles client follow-up, document collection, AI classification, and reminders — all on autopilot.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://cal.com/heshbonai/intro" class="btn-primary">Schedule your intro call</a>
          <a href="/contact" class="btn-secondary">Contact us</a>
        </div>
      </div>
    </section>

    <!-- What gets automated -->
    <section class="py-16 md:py-24 bg-navy-light">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="section-label mb-4">CPA Firm Automation</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white">What HeshbonAI automates for you</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Card 1: Auto Reminders -->
          <div class="card">
            <div class="w-12 h-12 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Automatic reminders</h3>
            <p class="text-muted">WhatsApp reminders for missing documents — without picking up the phone or typing a single message.</p>
          </div>
          <!-- Card 2: Document Collection -->
          <div class="card">
            <div class="w-12 h-12 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Document collection</h3>
            <p class="text-muted">Clients send documents directly via WhatsApp — no portals, no apps, no friction.</p>
          </div>
          <!-- Card 3: AI Document Classification -->
          <div class="card">
            <div class="w-12 h-12 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">AI document classification</h3>
            <p class="text-muted">Automatic identification of invoices, receipts, and bank statements — no manual sorting, no mistakes.</p>
          </div>
          <!-- Card 4: Client Tracking -->
          <div class="card">
            <div class="w-12 h-12 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Client tracking</h3>
            <p class="text-muted">A real-time dashboard showing what arrived and what's missing — per client, per period.</p>
          </div>
          <!-- Card 5: Daily Summaries -->
          <div class="card">
            <div class="w-12 h-12 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Daily summaries</h3>
            <p class="text-muted">An automatic daily report for your team on document status — who sent what, what's missing, what's urgent.</p>
          </div>
          <!-- Card 6: Accounting Software Integration -->
          <div class="card">
            <div class="w-12 h-12 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Accounting software integration</h3>
            <p class="text-muted">Works with QuickBooks, Xero, Sage, FreshBooks, and more — no need to switch systems.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- OCR Section -->
    <section class="py-16 md:py-24 bg-navy">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="section-label mb-4">OCR for Invoices &amp; Receipts</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">OCR for invoices and receipts — automatic recognition</h2>
          <p class="text-lg text-muted max-w-3xl mx-auto">
            When a client sends a photo of a receipt or invoice via WhatsApp, the AI reads the document, extracts key fields — amount, date, vendor — classifies it automatically, and matches it to the right client.
          </p>
        </div>
        <div class="max-w-2xl mx-auto space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-success/10 flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold text-lg">Extracts amount, date, and vendor from images</p>
              <p class="text-muted">The AI reads every image sent and extracts relevant data in seconds.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-success/10 flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold text-lg">Auto-classification — invoice, receipt, bank statement</p>
              <p class="text-muted">Every document is automatically tagged by type — no manual sorting required.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-success/10 flex items-center justify-center flex-shrink-0 mt-1">
              <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold text-lg">Matched to the right client and request automatically</p>
              <p class="text-muted">Documents are linked to the correct client without dragging files between folders.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Before/After -->
    <section class="py-16 md:py-24 bg-navy-light">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="section-label mb-4">Comparison</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white">Before and after HeshbonAI</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Before -->
          <div class="card border-error/30">
            <h3 class="text-2xl font-bold text-white mb-6 text-center">Before</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-error/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>
                <p class="text-muted">Manually chasing every client — messages, calls, follow-ups</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-error/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>
                <p class="text-muted">Emails that never get opened and portals nobody uses</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-error/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>
                <p class="text-muted">Documents in the wrong folders — chaos, misfiling errors</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-error/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>
                <p class="text-muted">10+ hours per week on follow-up instead of professional work</p>
              </div>
            </div>
          </div>
          <!-- After -->
          <div class="card border-success/30">
            <h3 class="text-2xl font-bold text-white mb-6 text-center">After</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-success/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-muted">Automatic WhatsApp reminders — zero human effort</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-success/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-muted">82% response rate on WhatsApp — clients reply because it's easy</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-success/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-muted">AI-powered classification — every document in the right place</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-success/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-muted">10+ hours back for real work — accounting, advisory, growth</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-16 md:py-24 bg-navy border-t border-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Ready to automate your firm?</h2>
        <p class="text-lg text-muted mb-10 max-w-xl mx-auto">
          Let HeshbonAI handle the chasing, collecting, and sorting — so you can get back to real accounting.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://cal.com/heshbonai/intro" class="btn-primary">Schedule your intro call</a>
          <a href="/pricing" class="btn-secondary">See Pricing</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
