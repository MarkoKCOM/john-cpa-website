---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Book a Demo — JOHN | AI Document Collection for CPAs"
  description="See JOHN in action. Book a 15-minute demo and watch JOHN handle document collection for your client list live."
>
  <Navbar />

  <main class="pt-24">
    <section class="py-20 md:py-28">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <!-- Left: Info -->
          <div>
            <p class="section-label mb-4">Get Started</p>
            <h1 class="text-4xl md:text-5xl font-bold mb-6">
              See JOHN in action
            </h1>
            <p class="text-lg text-cool-gray mb-8">
              Book a 15-minute demo. We'll show you how JOHN handles document collection
              for a firm like yours — using your actual client scenarios.
            </p>

            <div class="space-y-6 mb-8">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-electric/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold">15 minutes, no fluff</p>
                  <p class="text-cool-gray text-sm">We respect your time. Quick demo, real answers.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-mint/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-mint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold">Your scenarios, not ours</p>
                  <p class="text-cool-gray text-sm">Tell us your client count and we'll show relevant results.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-whatsapp/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-whatsapp" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold">Live WhatsApp walkthrough</p>
                  <p class="text-cool-gray text-sm">See exactly what your clients will experience.</p>
                </div>
              </div>
            </div>

            <div class="card">
              <p class="text-sm text-cool-gray mb-2">Prefer to start right away?</p>
              <a href="#" class="btn-primary w-full">Start Your 14-Day Free Trial</a>
              <p class="text-xs text-cool-gray/60 mt-2 text-center">No credit card required</p>
            </div>
          </div>

          <!-- Right: Contact Form -->
          <div class="card">
            <h2 class="text-2xl font-bold mb-6">Book your demo</h2>
            <form id="demo-form" class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium text-cool-gray mb-1.5">Full name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-navy border border-cool-gray/20 rounded-lg text-off-white placeholder-cool-gray/50
                         focus:outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors"
                  placeholder="Yael Davidovich"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-cool-gray mb-1.5">Work email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-navy border border-cool-gray/20 rounded-lg text-off-white placeholder-cool-gray/50
                         focus:outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors"
                  placeholder="yael@firm.co.il"
                />
              </div>
              <div>
                <label for="firm" class="block text-sm font-medium text-cool-gray mb-1.5">Firm name</label>
                <input
                  type="text"
                  id="firm"
                  name="firm"
                  required
                  class="w-full px-4 py-3 bg-navy border border-cool-gray/20 rounded-lg text-off-white placeholder-cool-gray/50
                         focus:outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors"
                  placeholder="Davidovich & Levi Accounting"
                />
              </div>
              <div>
                <label for="clients" class="block text-sm font-medium text-cool-gray mb-1.5">How many clients do you manage?</label>
                <select
                  id="clients"
                  name="clients"
                  required
                  class="w-full px-4 py-3 bg-navy border border-cool-gray/20 rounded-lg text-off-white
                         focus:outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors"
                >
                  <option value="" disabled selected>Select range</option>
                  <option value="1-25">1-25 clients</option>
                  <option value="26-50">26-50 clients</option>
                  <option value="51-100">51-100 clients</option>
                  <option value="101-200">101-200 clients</option>
                  <option value="200+">200+ clients</option>
                </select>
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-cool-gray mb-1.5">Phone (optional)</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 bg-navy border border-cool-gray/20 rounded-lg text-off-white placeholder-cool-gray/50
                         focus:outline-none focus:border-electric focus:ring-1 focus:ring-electric transition-colors"
                  placeholder="+972-50-123-4567"
                />
              </div>
              <button type="submit" class="btn-primary w-full text-lg py-4">
                Book My Demo
              </button>
              <p class="text-xs text-cool-gray/60 text-center">
                We'll respond within 4 hours during business days (Sun-Thu).
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="py-16 bg-charcoal/50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-2xl font-bold mb-8">Other ways to reach us</h2>
        <div class="grid sm:grid-cols-3 gap-6">
          <div class="card text-center">
            <svg class="w-8 h-8 text-electric mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <p class="font-semibold mb-1">Email</p>
            <p class="text-cool-gray text-sm">hello@heshbonai.co</p>
          </div>
          <div class="card text-center">
            <svg class="w-8 h-8 text-whatsapp mx-auto mb-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <p class="font-semibold mb-1">WhatsApp</p>
            <p class="text-cool-gray text-sm">+972-XX-XXX-XXXX</p>
          </div>
          <div class="card text-center">
            <svg class="w-8 h-8 text-electric mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="font-semibold mb-1">Location</p>
            <p class="text-cool-gray text-sm">Tel Aviv, Israel</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
