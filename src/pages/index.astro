---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import PainPoints from '../components/PainPoints.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Integrations from '../components/Integrations.astro';
import WhatsAppDemo from '../components/WhatsAppDemo.astro';
import Features from '../components/Features.astro';
import ROICalculator from '../components/ROICalculator.astro';
import Onboarding from '../components/Onboarding.astro';
import PricingSnapshot from '../components/PricingSnapshot.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="HeshbonAI — The AI Assistant for CPA Firms"
  description="Automate client follow-up, document collection, and status tracking through WhatsApp. Built for Israeli CPA firms. Fits your current workflow."
>
  <Navbar />
  <main>
    <Hero />
    <PainPoints />
    <HowItWorks />
    <Integrations />
    <WhatsAppDemo />
    <Features />
    <ROICalculator />
    <Onboarding />
    <PricingSnapshot />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
