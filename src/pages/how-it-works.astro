---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="How HeshbonAI Works - AI Document Collection via WhatsApp"
  description="See how HeshbonAI automates client follow-up and document collection through WhatsApp in 5 steps. Define needs, follow up automatically, receive documents, classify with AI, and track everything."
>
  <Navbar />

  <main class="pt-24">
    <section class="py-20 md:py-28 bg-navy">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="section-label mb-4">How It Works</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white">
          Five steps to zero chasing.
        </h1>
        <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto">
          Define what's needed. HeshbonAI handles the follow-up. Your team gets full visibility.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-navy-light">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="space-y-16 md:space-y-24">
          <!-- Step 1 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">1</div>
                <p class="section-label">Define</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Define what each client needs</h2>
              <p class="text-muted text-lg mb-6">
                Import your client list, assign the required documents per client, and set deadlines.
                Upload a CSV or connect your accounting software directly. We guide you through everything during onboarding.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">CSV upload or accounting software integration</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">QuickBooks, Xero, Sage, FreshBooks, Zoho Books, Wave</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Guided setup during onboarding</span>
                </li>
              </ul>
            </div>
            <div class="card text-center">
              <svg class="w-20 h-20 mx-auto text-blue/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
              </svg>
              <p class="text-muted mt-4">Upload CSV or connect your accounting software</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">2</div>
                <p class="section-label">Automate</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">The assistant follows up automatically</h2>
              <p class="text-muted text-lg mb-6">
                HeshbonAI messages each client on WhatsApp from your firm's branded number.
                Smart scheduling ensures messages go out at the right time. Respects quiet hours and local holidays.
                Escalates to your team when needed. Accountants can also message the assistant directly to check status.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Smart scheduling with quiet hours and holiday awareness</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Escalates to your team only when needed</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Accountants can message the assistant to check status</span>
                </li>
              </ul>
            </div>
            <div class="md:order-1">
              <div class="rounded-2xl overflow-hidden border border-border shadow-lg max-w-sm mx-auto">
                <div class="bg-[#075E54] px-4 py-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-white text-xs font-bold">LC</div>
                  <div>
                    <p class="text-white text-sm font-semibold">Palmer & Co.</p>
                    <p class="text-white/60 text-xs">online</p>
                  </div>
                </div>
                <div class="bg-[#0B141A] px-3 py-4 space-y-2">
                  <div class="flex justify-start">
                    <div class="max-w-[85%] rounded-lg px-3 py-2 bg-[#1F2C34] text-[#E9EDEF]" style="border-top-left-radius: 2px;">
                      <p class="text-[#00A884] text-xs font-medium mb-1">John</p>
                      <p class="text-sm leading-relaxed">Hi James, we need 3 documents for your annual filing. Can you send them here?</p>
                      <div class="flex justify-end mt-1"><span class="text-[10px] text-[#8696A0]">10:02</span></div>
                    </div>
                  </div>
                  <div class="flex justify-end">
                    <div class="max-w-[85%] rounded-lg px-3 py-2 bg-[#005C4B] text-[#E9EDEF]" style="border-top-right-radius: 2px;">
                      <p class="text-sm">Sure, let me find them!</p>
                      <div class="flex justify-end mt-1"><span class="text-[10px] text-[#8696A0]">11:47</span></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">3</div>
                <p class="section-label">Receive</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Client sends documents</h2>
              <p class="text-muted text-lg mb-6">
                The client replies on WhatsApp with a photo or file. No portal, no app, no signup required.
                The assistant confirms receipt immediately so the client knows it went through.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Reply with photo or file directly on WhatsApp</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">No portal, no app, no signup</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Instant confirmation of receipt</span>
                </li>
              </ul>
            </div>
            <div class="card text-center">
              <svg class="w-20 h-20 mx-auto text-blue/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <p class="text-muted mt-4">Client sends a photo or file on WhatsApp -- done</p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">4</div>
                <p class="section-label">Classify</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">System confirms and tracks</h2>
              <p class="text-muted text-lg mb-6">
                AI classifies the document, updates its status, and notifies your team.
                Each document is automatically matched to the right client and request -- no manual sorting.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">AI document classification (bank statements, receipts, forms)</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Auto-matches document to client and request</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Team notified on each new document</span>
                </li>
              </ul>
            </div>
            <div class="md:order-1 card text-center">
              <svg class="w-20 h-20 mx-auto text-blue/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
              <p class="text-muted mt-4">AI classifies and matches each document automatically</p>
            </div>
          </div>

          <!-- Step 5 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">5</div>
                <p class="section-label">Track</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Your team gets daily visibility</h2>
              <p class="text-muted text-lg mb-6">
                One dashboard showing who sent what, what's missing, and what's overdue.
                Daily summary reports keep your team informed. Export to your accounting software when ready.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Real-time document status tracking</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">Daily summary reports</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">One-click export to QuickBooks, Xero, Sage, and more</span>
                </li>
              </ul>
            </div>
            <div class="card">
              <div class="flex items-center justify-between mb-6">
                <h3 class="font-semibold text-white text-sm">Document Status</h3>
                <span class="text-xs text-muted">Updated just now</span>
              </div>
              <div class="space-y-4">
                <div>
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="text-offwhite">James Carter</span>
                    <span class="text-success font-mono text-xs">3/3 Complete</span>
                  </div>
                  <div class="w-full bg-navy rounded-full h-1.5">
                    <div class="bg-success h-1.5 rounded-full" style="width: 100%"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="text-offwhite">Sarah Palmer</span>
                    <span class="text-blue font-mono text-xs">2/4 In Progress</span>
                  </div>
                  <div class="w-full bg-navy rounded-full h-1.5">
                    <div class="bg-blue h-1.5 rounded-full" style="width: 50%"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="text-offwhite">Marco Rossi</span>
                    <span class="text-warning font-mono text-xs">0/5 Pending</span>
                  </div>
                  <div class="w-full bg-navy rounded-full h-1.5">
                    <div class="bg-warning h-1.5 rounded-full" style="width: 3%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-navy border-t border-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Ready to let HeshbonAI handle it?
        </h2>
        <p class="text-muted text-lg mb-8">
          Guided onboarding. See results in your first week.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://cal.com/heshbonai/intro" class="btn-primary text-lg px-8 py-4">Schedule your intro call</a>
          <a href="/contact" class="btn-secondary text-lg px-8 py-4">Send a Message</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
