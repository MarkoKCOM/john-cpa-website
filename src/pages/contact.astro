---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Contact Us — HeshbonAI | AI Assistant for CPA Firms"
  description="Get in touch with HeshbonAI. Tell us about your firm and we'll show you how we automate client follow-up and document collection."
>
  <Navbar />

  <main class="pt-24">
    <section class="py-20 md:py-28 bg-navy">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <div>
            <p class="section-label mb-4">Get Started</p>
            <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white">
              Let's talk about your firm
            </h1>
            <p class="text-lg text-muted mb-8">
              Tell us about your firm and how many clients you manage. We'll walk you through how HeshbonAI can help.
            </p>

            <div class="space-y-6 mb-8">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-white">15 minutes, no fluff</p>
                  <p class="text-muted text-sm">We respect your time. Quick call, real answers.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-white">Your scenarios, not ours</p>
                  <p class="text-muted text-sm">Tell us your client count and we'll show relevant results.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-whatsapp/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-whatsapp" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-white">Live WhatsApp walkthrough</p>
                  <p class="text-muted text-sm">See exactly what your clients will experience.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="card">
            <h2 class="text-2xl font-bold text-white mb-6">Get in touch</h2>
            <form id="contact-form" class="space-y-5" action="https://formspree.io/f/FORM_ID" method="POST">
              <div>
                <label for="name" class="block text-sm font-medium text-muted mb-1.5">Full name</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 bg-navy border border-border rounded-lg text-white placeholder-muted/50
                         focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-colors" placeholder="Yael Davidovich" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-muted mb-1.5">Work email</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 bg-navy border border-border rounded-lg text-white placeholder-muted/50
                         focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-colors" placeholder="yael@firm.co.il" />
              </div>
              <div>
                <label for="firm" class="block text-sm font-medium text-muted mb-1.5">Firm name</label>
                <input type="text" id="firm" name="firm" required
                  class="w-full px-4 py-3 bg-navy border border-border rounded-lg text-white placeholder-muted/50
                         focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-colors" placeholder="Davidovich & Levi Accounting" />
              </div>
              <div>
                <label for="clients" class="block text-sm font-medium text-muted mb-1.5">How many clients do you manage?</label>
                <select id="clients" name="clients" required
                  class="w-full px-4 py-3 bg-navy border border-border rounded-lg text-white
                         focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-colors">
                  <option value="" disabled selected>Select range</option>
                  <option value="1-25">1-25 clients</option>
                  <option value="26-50">26-50 clients</option>
                  <option value="51-100">51-100 clients</option>
                  <option value="101-200">101-200 clients</option>
                  <option value="200+">200+ clients</option>
                </select>
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-muted mb-1.5">Phone (optional)</label>
                <input type="tel" id="phone" name="phone"
                  class="w-full px-4 py-3 bg-navy border border-border rounded-lg text-white placeholder-muted/50
                         focus:outline-none focus:border-blue focus:ring-1 focus:ring-blue transition-colors" placeholder="+972-50-123-4567" />
              </div>
              <button type="submit" id="submit-btn" class="btn-primary w-full text-lg py-4">
                Send Message
              </button>
              <div id="form-status" class="hidden text-center text-sm py-2 rounded-lg"></div>
              <p class="text-xs text-muted/60 text-center">
                We'll respond within 4 hours during business days (Sun-Thu).
              </p>
            </form>

            <div class="mt-6 pt-6 border-t border-border text-center">
              <p class="text-sm text-muted mb-3">Prefer to schedule directly?</p>
              <a href="https://cal.com/heshbonai/intro" target="_blank" rel="noopener noreferrer"
                class="btn-secondary w-full text-center inline-flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Schedule a 15-min Call
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-navy-light border-t border-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-2xl font-bold text-white mb-8">Other ways to reach us</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="card text-center">
            <svg class="w-8 h-8 text-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <p class="font-semibold text-white mb-1">Email</p>
            <a href="mailto:support@heshbonai.co" class="text-blue text-sm hover:underline">support@heshbonai.co</a>
          </div>
          <div class="card text-center">
            <svg class="w-8 h-8 text-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="font-semibold text-white mb-1">Location</p>
            <p class="text-muted text-sm">Tel Aviv, Israel</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('contact-form');
      const btn = document.getElementById('submit-btn');
      const status = document.getElementById('form-status');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        btn.disabled = true;
        btn.textContent = 'Sending...';
        status.classList.add('hidden');

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'Accept': 'application/json' },
          });

          if (res.ok) {
            status.textContent = 'Message sent. We\'ll be in touch shortly.';
            status.className = 'text-center text-sm py-2 rounded-lg text-success';
            form.reset();
          } else {
            throw new Error('Submission failed');
          }
        } catch {
          status.textContent = 'Something went wrong. Email us at marko@heshbonai.co instead.';
          status.className = 'text-center text-sm py-2 rounded-lg text-error';
        }

        btn.disabled = false;
        btn.textContent = 'Send Message';
      });
    });
  </script>
</Layout>
