---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Pricing — JOHN | AI Document Collection for CPAs';
const description = 'Simple per-client pricing starting at $10/client/month. No setup fees, no annual contracts. 14-day free trial.';
---

<Layout title={title} description={description} canonical="https://heshbonai.co/pricing">
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-4 bg-forest-pale">
      <div class="max-w-4xl mx-auto text-center">
        <span class="section-label">Pricing</span>
        <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-slate-900">
          Simple Pricing. Pay Per Client.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-slate-600 max-w-2xl mx-auto">
          No setup fees. No annual contracts. Start free for 14 days.
        </p>
      </div>
    </section>

    <!-- Pricing Tiers -->
    <section class="pb-20 px-4 bg-white pt-16">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start">

        <!-- Starter -->
        <div class="bg-white rounded-2xl border border-slate-200 p-8 flex flex-col h-full shadow-sm">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-slate-900">Starter</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-slate-900 font-display">$15</span>
              <span class="text-slate-500 text-sm">/client/mo</span>
            </div>
            <p class="mt-2 text-sm text-slate-500">Up to 50 clients</p>
          </div>
          <a href="mailto:markos@heshbonai.co" class="btn-secondary w-full text-center mb-8">Start Free Trial</a>
          <ul class="space-y-3 text-sm text-slate-700 flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>WhatsApp document collection</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Up to 3 follow-ups per client</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Document recognition</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Dashboard</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Hebrew + English</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Email support</li>
          </ul>
        </div>

        <!-- Growth -->
        <div class="bg-forest rounded-2xl p-8 flex flex-col h-full text-white ring-2 ring-forest shadow-xl relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-amber text-slate-900 text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">Most Popular</span>
          </div>
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">Growth</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white font-display">$10</span>
              <span class="text-white/70 text-sm">/client/mo</span>
            </div>
            <p class="mt-2 text-sm text-white/70">51 - 200 clients</p>
          </div>
          <a href="mailto:markos@heshbonai.co" class="inline-flex items-center justify-center px-6 py-3 bg-white text-forest font-semibold rounded-lg hover:bg-forest-pale transition-all duration-200 text-sm shadow-sm w-full text-center mb-8">Start Free Trial</a>
          <p class="text-xs text-white/60 mb-4">Everything in Starter, plus:</p>
          <ul class="space-y-3 text-sm text-white/90 flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Unlimited follow-ups</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Deadline priority engine</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Multi-language (Arabic, Russian)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Custom message templates</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Team dashboard (up to 5 CPAs)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>CSV / API export</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Priority support</li>
          </ul>
        </div>

        <!-- Enterprise -->
        <div class="bg-white rounded-2xl border border-slate-200 p-8 flex flex-col h-full shadow-sm">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-slate-900">Enterprise</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-slate-900 font-display">Custom</span>
            </div>
            <p class="mt-2 text-sm text-slate-500">200+ clients</p>
          </div>
          <a href="mailto:markos@heshbonai.co?subject=Enterprise Inquiry" class="btn-secondary w-full text-center mb-8">Contact Sales</a>
          <p class="text-xs text-slate-400 mb-4">Everything in Growth, plus:</p>
          <ul class="space-y-3 text-sm text-slate-700 flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Unlimited team members</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Custom integrations (Hashavshevet, Priority, SAP)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>White-label option</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Dedicated account manager</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>SLA 99.9% uptime</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-forest shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Phone + WhatsApp support</li>
          </ul>
        </div>
      </div>

      <p class="text-center text-slate-500 text-sm mt-8 max-w-xl mx-auto">
        All plans include a <strong class="text-slate-900">14-day free trial</strong>. Pay annually and get <strong class="text-slate-900">2 months free</strong> (17% off).
      </p>
    </section>

    <!-- Cost Comparison -->
    <section class="py-20 px-4 bg-slate-50">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <span class="section-label">ROI</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-bold text-slate-900">JOHN Pays for Itself in Week One</h2>
          <p class="mt-4 text-slate-500 max-w-xl mx-auto">Based on a 100-client CPA firm at $50/hr billing rate.</p>
        </div>

        <div class="overflow-x-auto bg-white rounded-2xl border border-slate-200 shadow-sm">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-slate-200">
                <th class="py-4 px-6 text-slate-500 font-medium">Metric</th>
                <th class="py-4 px-6 text-slate-500 font-medium">Manual Process</th>
                <th class="py-4 px-6 text-forest font-medium">With JOHN</th>
              </tr>
            </thead>
            <tbody class="text-slate-700">
              <tr class="border-b border-slate-100">
                <td class="py-4 px-6 font-medium text-slate-900">Time on document chasing</td>
                <td class="py-4 px-6">8 hrs/week</td>
                <td class="py-4 px-6 text-forest font-medium">0 hrs/week</td>
              </tr>
              <tr class="border-b border-slate-100">
                <td class="py-4 px-6 font-medium text-slate-900">Weekly cost of chasing</td>
                <td class="py-4 px-6 text-coral">$400</td>
                <td class="py-4 px-6 text-forest font-medium">$0</td>
              </tr>
              <tr class="border-b border-slate-100">
                <td class="py-4 px-6 font-medium text-slate-900">Monthly cost of chasing</td>
                <td class="py-4 px-6 text-coral">$1,600</td>
                <td class="py-4 px-6 text-forest font-medium">$0</td>
              </tr>
              <tr class="border-b border-slate-100">
                <td class="py-4 px-6 font-medium text-slate-900">JOHN cost (100 clients)</td>
                <td class="py-4 px-6">--</td>
                <td class="py-4 px-6">$1,000 - $1,500/mo</td>
              </tr>
              <tr class="border-b border-slate-100">
                <td class="py-4 px-6 font-medium text-slate-900">Net monthly savings</td>
                <td class="py-4 px-6">--</td>
                <td class="py-4 px-6 text-forest font-bold text-base">$1,400/mo</td>
              </tr>
              <tr>
                <td class="py-4 px-6 font-medium text-slate-900">Client response rate</td>
                <td class="py-4 px-6">42%</td>
                <td class="py-4 px-6 text-forest font-medium">94%</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mt-8 bg-forest-pale rounded-2xl border border-forest-light/20 p-6 text-center">
          <p class="text-lg font-semibold text-slate-900">
            A 100-client firm saves <span class="text-forest font-bold">$1,400/month</span> and recovers <span class="text-forest font-bold">32 hours</span>.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 px-4 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="section-label">FAQ</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-bold text-slate-900">Frequently Asked Questions</h2>
        </div>

        <div class="space-y-3" id="faq-list">
          <div class="faq-item rounded-2xl border border-slate-200 overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-medium text-slate-900">What counts as a "client"?</span>
              <svg class="faq-icon w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">A client is any individual or business entity that JOHN contacts for document collection during a billing month. If a client is inactive (not contacted) in a given month, they don't count toward your total.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-slate-200 overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-medium text-slate-900">How does the 14-day free trial work?</span>
              <svg class="faq-icon w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">Sign up, connect your WhatsApp Business number, and start collecting immediately. No credit card required. Full access to all features in your chosen plan.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-slate-200 overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-medium text-slate-900">Can I change plans later?</span>
              <svg class="faq-icon w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">Yes. Upgrade or downgrade anytime. Upgrades are prorated. Downgrades take effect at next billing period.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-slate-200 overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-medium text-slate-900">Does my client need to install anything?</span>
              <svg class="faq-icon w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">No. Clients interact through WhatsApp or SMS — apps they already have. Nothing to download, no account to create.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-slate-200 overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-medium text-slate-900">How are sensitive documents protected?</span>
              <svg class="faq-icon w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">All documents are encrypted in transit (TLS 1.3) and at rest (AES-256). Access is logged and auditable.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-slate-200 overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-medium text-slate-900">What's the cancellation policy?</span>
              <svg class="faq-icon w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">Cancel anytime. Monthly plans end at close of billing cycle. Annual plans receive prorated refund for unused months.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="cta" class="py-20 px-4 bg-forest">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          14 Days Free. 5 Hours Back. Every Week.
        </h2>
        <p class="mt-6 text-white/70 text-lg max-w-xl mx-auto">
          Start collecting documents on autopilot today.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="mailto:markos@heshbonai.co" class="inline-flex items-center justify-center px-8 py-4 bg-white text-forest font-semibold rounded-lg hover:bg-forest-pale transition-all duration-200 text-lg shadow-sm">Start Free Trial</a>
          <a href="/demo" class="inline-flex items-center justify-center px-8 py-4 border border-white/30 text-white font-medium rounded-lg hover:bg-white/10 transition-all duration-200 text-lg">Book a Demo</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- FAQ Accordion Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toggles = document.querySelectorAll('.faq-toggle');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const item = toggle.closest('.faq-item');
          const content = item.querySelector('.faq-content');
          const icon = toggle.querySelector('.faq-icon');
          const isOpen = !content.classList.contains('hidden');

          document.querySelectorAll('.faq-item').forEach((otherItem) => {
            if (otherItem !== item) {
              const otherContent = otherItem.querySelector('.faq-content');
              const otherIcon = otherItem.querySelector('.faq-icon');
              const otherToggle = otherItem.querySelector('.faq-toggle');
              otherContent.classList.add('hidden');
              otherContent.style.maxHeight = null;
              otherIcon.style.transform = 'rotate(0deg)';
              otherToggle.setAttribute('aria-expanded', 'false');
            }
          });

          if (isOpen) {
            content.style.maxHeight = null;
            setTimeout(() => content.classList.add('hidden'), 200);
            icon.style.transform = 'rotate(0deg)';
            toggle.setAttribute('aria-expanded', 'false');
          } else {
            content.classList.remove('hidden');
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
            toggle.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  </script>

  <style>
    .faq-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .faq-content:not(.hidden) {
      max-height: none;
    }
    .faq-icon {
      transition: transform 0.2s ease;
    }
  </style>
</Layout>
