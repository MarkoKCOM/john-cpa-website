---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Pricing — JOHN | AI Document Collection for CPAs';
const description = 'Simple per-client pricing starting at $10/client/month. No setup fees, no annual contracts. 14-day free trial. JOHN automates document collection via WhatsApp so CPAs save 32+ hours per month.';
---

<Layout title={title} description={description} canonical="https://getjohn.ai/pricing">
  <Navbar />

  <main>
    <!-- ==================== HERO ==================== -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <span class="section-label">Pricing</span>
        <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
          Simple Pricing. Pay Per Client. <span class="gradient-text">Save Per Hour.</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-cool-gray max-w-2xl mx-auto">
          No setup fees. No annual contracts. Start free for 14 days.
        </p>
      </div>
    </section>

    <!-- ==================== PRICING TIERS ==================== -->
    <section class="pb-20 px-4">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start">

        <!-- Starter -->
        <div class="card flex flex-col h-full">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-off-white">Starter</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-off-white">$15</span>
              <span class="text-cool-gray text-sm">/client/mo</span>
            </div>
            <p class="mt-2 text-sm text-cool-gray">Up to 50 clients</p>
          </div>
          <a href="#cta" class="btn-secondary w-full text-center mb-8">Start Free Trial</a>
          <ul class="space-y-3 text-sm text-off-white/80 flex-1">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mint shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              WhatsApp document collection
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mint shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Up to 3 follow-ups per client
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mint shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Document recognition
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mint shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Dashboard
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mint shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Hebrew + English
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-mint shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Email support
            </li>
          </ul>
        </div>

        <!-- Growth (highlighted) -->
        <div class="card flex flex-col h-full border-electric/60 ring-1 ring-electric/30 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-electric text-white text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">Most Popular</span>
