---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Pricing — HeshbonAI | AI Assistant for CPA Firms';
const description = 'Flat monthly pricing in NIS. All plans include WhatsApp document collection, follow-ups, dashboard, and Hebrew support.';
---

<Layout title={title} description={description} canonical="https://heshbonai.co/pricing">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Will my clients know they're speaking with an assistant?",
        "acceptedAnswer": { "@type": "Answer", "text": "Messages come from your firm's branded WhatsApp Business number. The tone is professional and human. Most clients think it's a new team member." }
      },
      {
        "@type": "Question",
        "name": "Does HeshbonAI work in Hebrew?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. HeshbonAI is Hebrew-first. It also supports English, Arabic, and Russian for multi-language client bases." }
      },
      {
        "@type": "Question",
        "name": "Do clients need a portal or app?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Zero downloads. Zero signups. Clients respond on WhatsApp — the app they already use daily." }
      },
      {
        "@type": "Question",
        "name": "How long does setup take?",
        "acceptedAnswer": { "@type": "Answer", "text": "About 10 minutes. Import your client list, connect your WhatsApp Business account, and HeshbonAI starts working immediately." }
      },
      {
        "@type": "Question",
        "name": "Can our team review messages before they go out?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. You control message templates and follow-up timing. Your team can review, pause, or override any conversation at any time." }
      }
    ]
  })} />

  <Navbar />

  <main>
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-4 bg-navy">
      <div class="max-w-4xl mx-auto text-center">
        <span class="section-label">Pricing</span>
        <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white">
          Simple pricing for growing firms
        </h1>
        <p class="mt-6 text-lg md:text-xl text-muted max-w-2xl mx-auto">
          No per-client fees. No annual contracts. All prices excl. VAT.
        </p>
      </div>
    </section>

    <!-- Pricing Tiers -->
    <section class="pb-20 px-4 bg-navy-light pt-16">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start">

        <!-- Starter -->
        <div class="card flex flex-col h-full">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">Starter</h3>
            <p class="text-sm text-muted mt-1">For solo practitioners getting started with automation</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white font-display">&#8362;1,000</span>
              <span class="text-muted text-sm">/month</span>
            </div>
            <p class="mt-2 text-sm text-muted">Up to 50 clients</p>
          </div>
          <a href="/contact" class="btn-secondary w-full text-center mb-8">Get Started</a>
          <ul class="space-y-3 text-sm text-muted flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>WhatsApp document collection &amp; receipt confirmation</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Automated reminders &amp; follow-ups (up to 3 per doc)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Document tracking dashboard</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>FAQ bot — clients get instant answers</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Daily summary reports</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Hebrew + English</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Email support (24hr response)</li>
          </ul>
        </div>

        <!-- Professional -->
        <div class="bg-blue rounded-2xl p-8 flex flex-col h-full text-white ring-2 ring-blue shadow-xl shadow-blue/10 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-warning text-navy text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">Most Popular</span>
          </div>
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">Professional</h3>
            <p class="text-sm text-white/70 mt-1">For growing firms that need intelligence &amp; scale</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white font-display">&#8362;1,800</span>
              <span class="text-white/70 text-sm">/month</span>
            </div>
            <p class="mt-2 text-sm text-white/70">Up to 150 clients</p>
          </div>
          <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 bg-white text-blue font-semibold rounded-lg hover:bg-blue-pale transition-all duration-200 text-sm shadow-sm w-full text-center mb-8">Get Started</a>
          <p class="text-xs text-white/60 mb-4">Everything in Starter, plus:</p>
          <ul class="space-y-3 text-sm text-white/90 flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>AI document reading — auto-extract data from invoices, receipts, statements</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Unlimited follow-ups per document</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Automated monthly reports</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Deadline-based priority engine</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Multi-accountant support (up to 5 CPAs)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Multi-language (Arabic, Russian)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>CSV / API export</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Priority support (4hr response)</li>
          </ul>
        </div>

        <!-- Complete -->
        <div class="card flex flex-col h-full">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">Complete</h3>
            <p class="text-sm text-muted mt-1">Full automation for large firms and franchises</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white font-display">&#8362;2,700</span>
              <span class="text-muted text-sm">/month</span>
            </div>
            <p class="mt-2 text-sm text-muted">Up to 300 clients</p>
          </div>
          <a href="/contact" class="btn-secondary w-full text-center mb-8">Get Started</a>
          <p class="text-xs text-muted/60 mb-4">Everything in Professional, plus:</p>
          <ul class="space-y-3 text-sm text-muted flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Automated PDF &amp; report generation per client</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Smart scheduling — auto task prioritization</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Full integration (Hashavshevet, Priority, Rivhit, Green Invoice, QuickBooks, Xero)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Custom branding — your firm's name on all messages</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Unlimited team members</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Dedicated account manager</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>Phone + WhatsApp support</li>
          </ul>
        </div>
      </div>

      <p class="text-center text-muted text-sm mt-8 max-w-xl mx-auto">
        Onboarding fee may apply. Pay annually and get <strong class="text-white">2 months free</strong>. All prices excl. VAT.
      </p>
    </section>

    <!-- FAQ -->
    <section class="py-20 px-4 bg-navy">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="section-label">FAQ</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-bold text-white">Frequently Asked Questions</h2>
        </div>

        <div class="space-y-3" id="faq-list">
          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">Will clients know they're speaking with an assistant?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">Messages come from your firm's branded WhatsApp Business number with your firm name and logo. The tone is professional and human. Most clients think it's a new team member. If a client asks something the assistant can't answer, it flags it for your team.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">Does it work in Hebrew?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">Yes. HeshbonAI is Hebrew-first. It also supports English, Arabic, and Russian for multi-language client bases.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">Can our team review messages?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">Yes. You control message templates and follow-up timing. Your team can review, pause, or override any conversation. There's a full audit trail of every message sent.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">What if a client asks something complex?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">The assistant escalates to your team immediately instead of guessing. It responds: "Good question — let me check with the team and get back to you." Then flags it in your dashboard.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">Can we control follow-up timing?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">Yes. You set the follow-up schedule (minimum 3 days between messages). The assistant never messages before 8:00 AM or after 8:00 PM. It respects Shabbat and holidays automatically.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">Do clients need a portal or app?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">No. Zero downloads. Zero signups. Clients respond on WhatsApp — the app they already use daily. Just reply with a photo or file.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">How long does setup take?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">About 10 minutes. Import your client list (CSV or direct integration), connect your WhatsApp Business account, and HeshbonAI starts working immediately.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">Is WhatsApp Business required?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">Yes. HeshbonAI uses the official WhatsApp Business API. We guide you through setup if you don't have it yet — most firms are set up within a day.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Billing -->
    <section class="py-12 px-4 bg-navy-light border-t border-border">
      <div class="max-w-3xl mx-auto text-center text-xs text-muted/60 space-y-1">
        <p>All prices in NIS, excl. VAT (17% MA'AM for Israeli entities).</p>
        <p>Billed monthly by default. Annual billing available at 17% discount.</p>
        <p>Payment: credit card or bank transfer. Israeli tax invoice (Hashbonit Mas) provided.</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-4 bg-navy border-t border-border">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Let your team focus on accounting
        </h2>
        <p class="mt-6 text-muted text-lg max-w-xl mx-auto">
          HeshbonAI handles the follow-up. Your staff handles the accounting.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="btn-primary text-lg px-8 py-4">Get Started</a>
          <a href="mailto:marko@heshbonai.co" class="btn-secondary text-lg px-8 py-4">Email Us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toggles = document.querySelectorAll('.faq-toggle');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const item = toggle.closest('.faq-item');
          const content = item.querySelector('.faq-content');
          const icon = toggle.querySelector('.faq-icon');
          const isOpen = !content.classList.contains('hidden');

          document.querySelectorAll('.faq-item').forEach((otherItem) => {
            if (otherItem !== item) {
              otherItem.querySelector('.faq-content').classList.add('hidden');
              otherItem.querySelector('.faq-content').style.maxHeight = null;
              otherItem.querySelector('.faq-icon').style.transform = 'rotate(0deg)';
              otherItem.querySelector('.faq-toggle').setAttribute('aria-expanded', 'false');
            }
          });

          if (isOpen) {
            content.style.maxHeight = null;
            setTimeout(() => content.classList.add('hidden'), 200);
            icon.style.transform = 'rotate(0deg)';
            toggle.setAttribute('aria-expanded', 'false');
          } else {
            content.classList.remove('hidden');
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
            toggle.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  </script>

  <style>
    .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .faq-content:not(.hidden) { max-height: none; }
    .faq-icon { transition: transform 0.2s ease; }
  </style>
</Layout>
