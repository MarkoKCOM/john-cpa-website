          <div class="mb-6">
            <h3 class="text-lg font-semibold text-off-white">Growth</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-off-white">$10</span>
              <span class="text-cool-gray text-sm">/client/mo</span>
            </div>
            <p class="mt-2 text-sm text-cool-gray">51 - 200 clients</p>
          </div>
          <a href="#cta" class="btn-primary w-full text-center mb-8">Start Free Trial</a>
