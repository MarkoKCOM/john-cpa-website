        <div class="space-y-3" id="he-faq-list">
          {faqs.map((faq) => (
            <div class="faq-item-he rounded-2xl border border-border overflow-hidden">
              <button class="faq-toggle-he w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
                <span class="font-medium text-white">{faq.question}</span>
                <svg class="faq-icon-he w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="faq-content-he hidden px-6 pb-5">
                <p class="text-muted text-sm leading-relaxed">{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>

        <p class="text-muted text-sm text-center mt-8">
          יש שאלה נוספת? <a href="/he/contact" class="text-blue hover:text-blue/80 underline underline-offset-2">צרו קשר</a>.
        </p>
      </div>
    </section>

    <script>
      const faqListHe = document.getElementById('he-faq-list');
      if (faqListHe) {
        faqListHe.querySelectorAll('.faq-toggle-he').forEach((toggle) => {
          toggle.addEventListener('click', () => {
            const item = toggle.closest('.faq-item-he');
            const content = item?.querySelector('.faq-content-he') as HTMLElement;
            const icon = toggle.querySelector('.faq-icon-he') as HTMLElement;
            if (!content || !icon) return;
            const isOpen = !content.classList.contains('hidden');

            faqListHe.querySelectorAll('.faq-item-he').forEach((otherItem) => {
              if (otherItem !== item) {
                const otherContent = otherItem.querySelector('.faq-content-he') as HTMLElement;
                const otherIcon = otherItem.querySelector('.faq-icon-he') as HTMLElement;
                const otherToggle = otherItem.querySelector('.faq-toggle-he');
                if (otherContent) { otherContent.classList.add('hidden'); otherContent.style.maxHeight = ''; }
                if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
                if (otherToggle) otherToggle.setAttribute('aria-expanded', 'false');
              }
            });

            if (isOpen) {
              content.style.maxHeight = '';
              setTimeout(() => content.classList.add('hidden'), 200);
              icon.style.transform = 'rotate(0deg)';
              toggle.setAttribute('aria-expanded', 'false');
            } else {
              content.classList.remove('hidden');
              content.style.maxHeight = content.scrollHeight + 'px';
              icon.style.transform = 'rotate(180deg)';
              toggle.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    </script>

    <style>
      .faq-content-he { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
      .faq-content-he:not(.hidden) { max-height: none; }
