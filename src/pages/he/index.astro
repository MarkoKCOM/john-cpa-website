---
import LayoutHe from '../../layouts/LayoutHe.astro';
import NavbarHe from '../../components/NavbarHe.astro';
import FooterHe from '../../components/FooterHe.astro';
import '../../styles/global.css';

const steps = [
  { title: "שיחת היכרות", description: "נלמד על המשרד שלכם, כמות הלקוחות, ואיך אתם עובדים היום. 15 דקות." },
  { title: "חיבור וואטסאפ", description: "נעזור לכם להגדיר או לחבר את חשבון ה-WhatsApp Business שלכם. אנחנו מטפלים בצד הטכני." },
  { title: "ייבוא לקוחות", description: "העלו רשימת לקוחות דרך CSV או חברו את תוכנת הנהלת החשבונות. אנחנו ממפים מסמכים ודדליינים." },
  { title: "הגדרה ובדיקה", description: "קבעו לוחות זמנים למעקב, תבניות הודעות וכללי ביקורת. בדקו עם כמה לקוחות לפני עלייה לאוויר." },
  { title: "עלייה לאוויר", description: "השקה לכל הלקוחות. הצוות שלכם מקבל גישה לדשבורד והדרכה. אנחנו זמינים לשבועיים הראשונים." },
];

const tiers = [
  {
    name: 'Starter',
    price: '\u20AA1,000',
    unit: '/חודש',
    description: 'כל הכלים הבסיסיים למשרדים קטנים',
    clients: 'עד 25 לקוחות',
    setupFee: true,
    features: [
      'כל האינטגרציות כלולות',
      'מעקבים ללא הגבלה',
      'איסוף ואישור מסמכים בוואטסאפ',
      'דשבורד מעקב מסמכים',
      'עוזר שאלות נפוצות ללקוחות',
      'סיכומים יומיים',
      'עברית + אנגלית',
    ],
    highlighted: false,
  },
  {
    name: 'Professional',
    price: '\u20AA1,800',
    unit: '/חודש',
    description: 'קריאת מסמכים, חילוץ נתונים ורב-משתמשים',
    clients: 'עד 150 לקוחות',
    setupFee: false,
    features: [
      'הכל מתוכנית Starter',
      'קריאת מסמכים וחילוץ נתונים ב-AI',
      'דוחות חודשיים אוטומטיים',
      'ריבוי רואי חשבון (עד 5)',
      'רב-שפתי (רוסית, ערבית, צרפתית)',
      'ייצוא CSV / API',
      'תמיכה מועדפת (4 שעות)',
    ],
    highlighted: true,
  },
  {
    name: 'Complete',
    price: '\u20AA2,700',
    unit: '/חודש',
    description: 'אינטגרציה מלאה, דוחות ומיתוג',
    clients: 'עד 300 לקוחות',
    setupFee: false,
    features: [
      'הכל מתוכנית Professional',
      'יצירת PDF ודוחות אוטומטית',
      'אינטגרציה מלאה לתוכנות',
      'מיתוג מותאם (white-label)',
      'חברי צוות ללא הגבלה',
      'מנהל לקוח ייעודי',
    ],
    highlighted: false,
  },
];

const faqs = [
  {
    question: "הלקוחות יידעו שהם מדברים עם עוזר אוטומטי?",
    answer: "ההודעות יוצאות ממספר ה-WhatsApp Business של המשרד שלכם, עם השם והלוגו שלכם. הטון מקצועי ואנושי. רוב הלקוחות חושבים שזה עובד חדש. אם לקוח שואל משהו שהעוזר לא יודע לענות עליו — הוא מסמן את זה לצוות שלכם.",
  },
  {
    question: "המערכת עובדת בעברית?",
    answer: "כן. HeshbonAI בנוי עברית-first. המערכת תומכת גם באנגלית, ערבית, רוסית וצרפתית לבסיסי לקוחות רב-שפתיים.",
  },
  {
    question: "הלקוחות צריכים פורטל או אפליקציה?",
    answer: "לא. אפס הורדות. אפס הרשמות. הלקוחות עונים בוואטסאפ — האפליקציה שהם כבר משתמשים בה כל יום. פשוט שולחים תמונה או קובץ.",
  },
  {
    question: "אפשר לבדוק הודעות לפני שהן יוצאות?",
    answer: "כן. אתם שולטים בתבניות ההודעות ובתזמון המעקבים. הצוות שלכם יכול לעיין, לעצור או לדרוס כל שיחה. יש מעקב מלא אחרי כל הודעה שנשלחה.",
  },
  {
    question: "כמה זמן לוקח ההטמעה?",
    answer: "כל משרד מקבל הטמעה מודרכת. אנחנו קובעים שיחת הגדרה, מייבאים את רשימת הלקוחות, מחברים וואטסאפ ומגדירים הכל ביחד. רוב המשרדים עולים לאוויר תוך כמה ימים.",
  },
  {
    question: "אפשר לשלוט בתזמון המעקבים?",
    answer: "כן. אתם קובעים את לוח הזמנים למעקב (מינימום 3 ימים בין הודעות). העוזר לעולם לא שולח לפני 8:00 בבוקר או אחרי 8:00 בערב. הוא מכבד שבת וחגים אוטומטית.",
  },
];
---

<LayoutHe
  title="HeshbonAI — העוזר החכם למשרד רו״ח | אוטומציה לאיסוף מסמכים"
  description="אוטומציה למעקב אחרי לקוחות ואיסוף מסמכים דרך וואטסאפ. בנוי למשרדי רואי חשבון בישראל. משתלב בכלים שלכם — בלי לשנות כלום."
>
  <NavbarHe />
  <main>

    <!-- Hero -->
    <section class="relative pt-32 pb-20 bg-navy overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.15] mb-6 text-white">
            הפסיקו לרדוף.<br />
            <span class="text-blue">תתחילו לנהל.</span>
          </h1>

          <p class="text-lg sm:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
            HeshbonAI מתאים לדרך שהמשרד שלכם כבר עובד — וואטסאפ, מייל, אקסל, ותוכנות חשבונאות. בלי לשנות כלום.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
            <a href="https://cal.com/heshbonai/intro" target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-8 py-4">
              קבעו שיחת היכרות
            </a>
            <a href="/he/contact" class="btn-secondary text-base px-8 py-4">
              צרו קשר
            </a>
          </div>

          <div class="flex flex-wrap items-center justify-center gap-4 text-muted text-sm">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              משרדי רו״ח בישראל
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-whatsapp" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              וואטסאפ
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              עברית מלאה
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              בלי פורטל ללקוח
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pain Points -->
    <section class="py-16 bg-navy-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">הכאב</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">הכאב שכל משרד מכיר</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">שעות על רדיפה אחרי מסמכים</h3>
            <p class="text-muted text-sm leading-relaxed">
              הצוות שולח תזכורות, בודק מי ענה, שולח שוב. רואי חשבון מקצועיים מבזבזים את הזמן שלהם על מעקב במקום על עבודה מקצועית.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-warning/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">הזנה ידנית של נתונים ממסמכים</h3>
            <p class="text-muted text-sm leading-relaxed">
              כל מסמך שמגיע צריך לפתוח, לקרוא, להקליד נתונים ידנית. טעויות בדרך, זמן שנשרף, ותסכול שמצטבר.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">אותן שאלות שוב ושוב</h3>
            <p class="text-muted text-sm leading-relaxed">
              &quot;מתי הדוח מוכן?&quot;, &quot;מה עוד צריך לשלוח?&quot;, &quot;מה המצב שלי?&quot; — הצוות עונה על אותן שאלות עשרות פעמים בחודש.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">דוחות נדחקים לסוף</h3>
            <p class="text-muted text-sm leading-relaxed">
              הדדליין מתקרב, אבל חצי מהלקוחות עדיין לא שלחו את מה שצריך. הדוח נדחה, הלחץ עולה, והלקוח לא מבין למה.
            </p>
          </div>

          <div class="card lg:col-span-2">
            <div class="w-12 h-12 rounded-xl bg-warning/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">עבודה מפוזרת בין וואטסאפ, מייל, אקסל וזיכרון</h3>
            <p class="text-muted text-sm leading-relaxed">
              אין מקום אחד לראות מי שלח מה ומה עדיין חסר. מידע חי בצ׳אטים, באימייל, בטבלאות, ובראש של מישהו שהיום לא בעבודה.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-16 bg-navy">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">איך זה עובד</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">איך HeshbonAI עובד</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
          <!-- Step 1 -->
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center mx-auto mb-4">
              <span class="text-blue font-bold text-lg">1</span>
            </div>
            <h3 class="text-white font-semibold text-base mb-2">הגדרה</h3>
            <p class="text-muted text-sm leading-relaxed">מגדירים מה כל לקוח צריך — חשבוניות, דפי בנק, תלושים, מה שצריך.</p>
          </div>

          <!-- Step 2 -->
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center mx-auto mb-4">
              <span class="text-blue font-bold text-lg">2</span>
            </div>
            <h3 class="text-white font-semibold text-base mb-2">מעקב אוטומטי</h3>
            <p class="text-muted text-sm leading-relaxed">HeshbonAI שולח תזכורות בוואטסאפ — בעברית, בשפה של הלקוח, עם רשימה מדויקת.</p>
          </div>

          <!-- Step 3 -->
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center mx-auto mb-4">
              <span class="text-blue font-bold text-lg">3</span>
            </div>
            <h3 class="text-white font-semibold text-base mb-2">הלקוח שולח</h3>
            <p class="text-muted text-sm leading-relaxed">תמונה או קובץ ישירות בוואטסאפ. בלי פורטלים, בלי סיסמאות, בלי לינקים.</p>
          </div>

          <!-- Step 4 -->
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center mx-auto mb-4">
              <span class="text-blue font-bold text-lg">4</span>
            </div>
            <h3 class="text-white font-semibold text-base mb-2">אישור ומעקב</h3>
            <p class="text-muted text-sm leading-relaxed">המערכת מאשרת קבלה, מסווגת אוטומטית, ומעדכנת את הסטטוס.</p>
          </div>

          <!-- Step 5 -->
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-success/10 border border-success/20 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-base mb-2">סיכום יומי</h3>
            <p class="text-muted text-sm leading-relaxed">הצוות מקבל תמונת מצב — מי השלים, מי חסר, מי דורש תשומת לב.</p>
          </div>
        </div>

        <div class="mt-12 max-w-2xl mx-auto text-center">
          <blockquote class="text-muted text-base italic border-r-2 border-blue pr-4">
            לא צריך לשנות את איך שהמשרד והלקוחות שלכם כבר עובדים. HeshbonAI משתלב בתהליך הקיים.
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Integrations -->
    <section class="py-16 bg-navy">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">אינטגרציות</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">עובד עם הכלים שכבר יש לכם</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          <div class="card">
            <div class="w-10 h-10 rounded-lg bg-whatsapp/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-whatsapp" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            </div>
            <h3 class="text-white font-semibold mb-2">WhatsApp</h3>
            <p class="text-muted text-sm">שליחת תזכורות, קבלת מסמכים ומענה אוטומטי ללקוחות — הכל דרך וואטסאפ.</p>
          </div>

          <div class="card">
            <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="text-white font-semibold mb-2">Email</h3>
            <p class="text-muted text-sm">קליטת מסמכים שמגיעים במייל ושילוב אוטומטי בתיקיית הלקוח.</p>
          </div>

