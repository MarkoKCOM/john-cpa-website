  <script>
    function runHeroAnimationHe() {
      const row = document.getElementById('hero-dana-row-he');
      if (!row) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.disconnect();
            setTimeout(animateDanaHe, 2000);
          }
        });
      }, { threshold: 0.5 });

      observer.observe(row);
    }

    function animateDanaHe() {
      const sub = document.getElementById('hero-dana-sub-he');
      const badge = document.getElementById('hero-dana-badge-he');
      const avatar = document.getElementById('hero-dana-avatar-he');
      const initials = document.getElementById('hero-dana-initials-he');
      const pulse = document.getElementById('hero-pulse-he');
      const timestamp = document.getElementById('hero-timestamp-he');
      if (!sub || !badge || !avatar || !initials || !pulse || !timestamp) return;

      sub.style.opacity = '0';
      setTimeout(() => {
        sub.textContent = '4/4 מסמכים התקבלו';
        sub.style.opacity = '1';
      }, 300);

      setTimeout(() => {
        badge.className = 'px-2 py-0.5 bg-success/10 text-success text-xs rounded font-medium transition-all duration-500';
        badge.textContent = 'הושלם';
      }, 400);

      setTimeout(() => {
        avatar.className = avatar.className.replace('bg-blue/10', 'bg-success/10');
        initials.className = initials.className.replace('text-blue', 'text-success');
      }, 400);

      setTimeout(() => {
        pulse.className = 'w-2 h-2 rounded-full bg-success animate-pulse transition-colors duration-500';
        timestamp.style.opacity = '0';
        setTimeout(() => {
          timestamp.textContent = 'עודכן ממש עכשיו';
          timestamp.className = 'text-success text-xs transition-opacity duration-300';
          timestamp.style.opacity = '1';
        }, 200);
      }, 600);
    }

    const hiwSectionHe = document.getElementById('how-it-works-he');
    if (hiwSectionHe) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.disconnect();
            hiwSectionHe.querySelectorAll('.hiw-step-he').forEach((step) => {
              (step as HTMLElement).style.opacity = '1';
              (step as HTMLElement).style.transform = 'translateY(0)';
            });
            const line = document.getElementById('hiw-line-he');
            if (line) {
              setTimeout(() => { line.style.transform = 'scaleX(1)'; }, 200);
            }
          }
        });
      }, { threshold: 0.2 });
      observer.observe(hiwSectionHe);
    }

    const waDemoHe = document.getElementById('wa-demo-he');
    if (waDemoHe) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.disconnect();

            waDemoHe.querySelectorAll('.wa-msg-he').forEach((msg) => {
              const el = msg as HTMLElement;
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            });

            setTimeout(() => {
              const dot = document.getElementById('wa-dot-1-he');
              const status = document.getElementById('wa-status-1-he');
              if (dot && status) {
                dot.className = 'w-2 h-2 rounded-full bg-success transition-colors duration-500';
                status.className = 'text-xs text-success font-medium transition-all duration-500';
                status.textContent = 'התקבל';
              }
            }, 1800);

            setTimeout(() => {
              const bar = document.getElementById('wa-dash-bar-he');
              const count = document.getElementById('wa-dash-count-he');
              const pulse = document.getElementById('wa-dash-pulse-he');
              const time = document.getElementById('wa-dash-time-he');
              if (bar && count) {
                bar.style.width = '33%';
                bar.className = 'bg-blue h-1.5 rounded-full transition-all duration-700 ease-out';
                count.textContent = '1/3';
                count.className = 'text-blue font-mono text-xs transition-colors duration-500';
              }
              if (pulse && time) {
                pulse.className = 'w-2 h-2 rounded-full bg-success animate-pulse transition-colors duration-500';
                time.style.opacity = '0';
                setTimeout(() => {
                  time.textContent = 'לייב, עודכן ממש עכשיו';
                  time.className = 'text-success text-xs transition-opacity duration-300';
                  time.style.opacity = '1';
                }, 200);
              }
            }, 2400);
          }
        });
      }, { threshold: 0.2 });
      observer.observe(waDemoHe);
    }

    function animateCountUpHe(el: HTMLElement, target: number, suffix: string, duration: number) {
      const start = performance.now();
      function tick(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * target);
        el.textContent = current + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const roiGridHe = document.getElementById('roi-grid-he');
    if (roiGridHe) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.disconnect();
            roiGridHe.querySelectorAll<HTMLElement>('[data-count-to]').forEach((el, i) => {
              const target = parseInt(el.dataset.countTo || '0', 10);
              const suffix = el.dataset.suffix || '';
              setTimeout(() => animateCountUpHe(el, target, suffix, 1200), i * 150);
            });
            roiGridHe.querySelectorAll<HTMLElement>('[data-count-text]').forEach((el) => {
              setTimeout(() => {
                el.style.transition = 'opacity 0.3s';
                el.style.opacity = '0';
                setTimeout(() => {
                  el.textContent = el.dataset.countText || '';
                  el.style.opacity = '1';
                }, 200);
              }, 3 * 150 + 400);
            });
          }
        });
      }, { threshold: 0.3 });
      observer.observe(roiGridHe);
    }

    const onboardingSectionHe = document.getElementById('onboarding-he');
    if (onboardingSectionHe) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.disconnect();
            onboardingSectionHe.querySelectorAll('.onboarding-step-he').forEach((step) => {
              (step as HTMLElement).style.opacity = '1';
              (step as HTMLElement).style.transform = 'translateY(0)';
            });
          }
        });
      }, { threshold: 0.2 });
      observer.observe(onboardingSectionHe);
    }

    const faqListHe = document.getElementById('homepage-faq-list-he');
    if (faqListHe) {
      faqListHe.querySelectorAll('.faq-toggle-he').forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const item = toggle.closest('.faq-item-he');
          const content = item?.querySelector('.faq-content-he') as HTMLElement | null;
          const icon = toggle.querySelector('.faq-icon-he') as HTMLElement | null;
          if (!content || !icon) return;
          const isOpen = !content.classList.contains('hidden');

          faqListHe.querySelectorAll('.faq-item-he').forEach((otherItem) => {
            if (otherItem !== item) {
              const otherContent = otherItem.querySelector('.faq-content-he') as HTMLElement | null;
              const otherIcon = otherItem.querySelector('.faq-icon-he') as HTMLElement | null;
              const otherToggle = otherItem.querySelector('.faq-toggle-he');
              if (otherContent) {
                otherContent.classList.add('hidden');
                otherContent.style.maxHeight = '';
              }
              if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
              if (otherToggle) otherToggle.setAttribute('aria-expanded', 'false');
            }
          });

          if (isOpen) {
            content.style.maxHeight = '';
            setTimeout(() => content.classList.add('hidden'), 200);
            icon.style.transform = 'rotate(0deg)';
            toggle.setAttribute('aria-expanded', 'false');
          } else {
            content.classList.remove('hidden');
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
            toggle.setAttribute('aria-expanded', 'true');
          }
        });
      });
    }

    runHeroAnimationHe();
  </script>

  <style>
    .faq-content-he { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .faq-content-he:not(.hidden) { max-height: none; }
    .faq-icon-he { transition: transform 0.2s ease; }
  </style>
</LayoutHe>
