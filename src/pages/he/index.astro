---
import LayoutHe from '../../layouts/LayoutHe.astro';
import NavbarHe from '../../components/NavbarHe.astro';
import FooterHe from '../../components/FooterHe.astro';
import '../../styles/global.css';

const steps = [
  {
    title: 'קבעו שיחת היכרות',
    description: 'נלמד על המשרד שלכם, כמות הלקוחות, ואיך אתם עובדים היום. 15 דקות.',
  },
  {
    title: 'חיבור WhatsApp',
    description: 'נעזור לכם להגדיר או לחבר את חשבון ה-WhatsApp Business שלכם. אנחנו מטפלים בצד הטכני.',
  },
  {
    title: 'ייבוא לקוחות',
    description: 'העלו רשימת לקוחות דרך CSV או חברו את תוכנת הנהלת החשבונות. אנחנו ממפים מסמכים ודדליינים.',
  },
  {
    title: 'הגדרה ובדיקה',
    description: 'קבעו לוחות זמנים למעקב, תבניות הודעות וכללי ביקורת. בדקו עם כמה לקוחות לפני עלייה לאוויר.',
  },
  {
    title: 'עלייה לאוויר עם הצוות',
    description: 'השקה לכל הלקוחות. הצוות שלכם מקבל גישה לדשבורד והדרכה. אנחנו זמינים לשבועיים הראשונים.',
  },
];

const tiers = [
  {
    name: 'Starter',
    price: '\u20AA1,000',
    unit: '/חודש',
    description: 'כל הכלים הבסיסיים למשרדים קטנים',
    clients: 'עד 25 לקוחות',
    setupFee: true,
    features: [
      'כל האינטגרציות כלולות',
      'מעקבים ללא הגבלה',
      'איסוף ואישור מסמכים בוואטסאפ',
      'דשבורד למעקב מסמכים',
      'עוזר FAQ לשאלות לקוחות',
      'סיכומים יומיים',
      'עברית + אנגלית',
    ],
    highlighted: false,
  },
  {
    name: 'Professional',
    price: '\u20AA1,800',
    unit: '/חודש',
    description: 'קריאת מסמכים, חילוץ נתונים וריבוי משתמשים',
    clients: 'עד 100 לקוחות',
    features: [
      'הכל ב-Starter',
      'קריאת מסמכים וחילוץ נתונים ב-AI',
      'דוחות חודשיים אוטומטיים',
      'ריבוי רואי חשבון (עד 5)',
      'רב-שפתי (רוסית, ערבית, צרפתית)',
      'ייצוא CSV / API',
      'תמיכה מועדפת (4 שעות)',
    ],
    highlighted: true,
  },
  {
    name: 'Complete',
    price: '\u20AA2,700',
    unit: '/חודש',
    description: 'אינטגרציה מלאה, דוחות ומיתוג',
    clients: 'עד 200 לקוחות',
    features: [
      'הכל ב-Professional',
      'יצירת PDF ודוחות אוטומטית',
      'אינטגרציה מלאה לתוכנות',
      'מיתוג מותאם (white-label)',
      'חברי צוות ללא הגבלה',
      'מנהל לקוח ייעודי',
    ],
    highlighted: false,
  },
];

const faqs = [
  {
    question: 'הלקוחות יידעו שהם מדברים עם עוזר?',
    answer:
      'ההודעות יוצאות ממספר ה-WhatsApp Business הממותג של המשרד שלכם עם שם המשרד והלוגו. הטון מקצועי ואנושי. רוב הלקוחות חושבים שזה עובד חדש. אם לקוח שואל משהו שהעוזר לא יודע לענות עליו, הוא מסמן את זה לצוות שלכם.',
  },
  {
    question: 'האם זה עובד בעברית?',
    answer:
      'כן. HeshbonAI בנוי עברית-first. המערכת תומכת גם באנגלית, ערבית, רוסית וצרפתית לבסיסי לקוחות רב-לשוניים.',
  },
  {
    question: 'הלקוחות צריכים פורטל או אפליקציה?',
    answer:
      'לא. אפס הורדות. אפס הרשמות. הלקוחות עונים בוואטסאפ, האפליקציה שהם כבר משתמשים בה כל יום. פשוט שולחים תמונה או קובץ.',
  },
  {
    question: 'האם הצוות יכול לבדוק הודעות לפני שהן יוצאות?',
    answer:
      'כן. אתם שולטים בתבניות ההודעות ובתזמון המעקבים. הצוות שלכם יכול לבדוק, לעצור או לדרוס כל שיחה. יש תיעוד מלא של כל הודעה שנשלחה.',
  },
  {
    question: 'כמה זמן לוקח ההטמעה?',
    answer:
      'כל משרד מקבל הטמעה מודרכת. אנחנו קובעים שיחת הגדרה, מייבאים את רשימת הלקוחות, מחברים WhatsApp ומגדירים הכל ביחד. רוב המשרדים עולים לאוויר תוך כמה ימים.',
  },
  {
    question: 'אפשר לשלוט בתזמון המעקבים?',
    answer:
      'כן. אתם קובעים את לוח הזמנים למעקב, עם מינימום 3 ימים בין הודעות. העוזר לא שולח לפני 08:00 או אחרי 20:00, ומכבד שבת וחגים אוטומטית.',
  },
];
---

<LayoutHe
  title="HeshbonAI - העוזר החכם למשרד רו״ח | אוטומציה לאיסוף מסמכים"
  description="אוטומציה למעקב אחרי לקוחות ואיסוף מסמכים דרך וואטסאפ. בנוי למשרדי רואי חשבון בישראל. משתלב בכלים שלכם בלי לשנות את תהליך העבודה."
  canonical="https://heshbonai.co/he/"
>
  <NavbarHe />
  <main>
    <section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 bg-navy overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="text-right">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-6 text-white">
              העוזר החכם<br />
              <span class="text-blue">למשרדי רו״ח</span>
            </h1>

            <p class="text-lg text-muted max-w-lg mr-auto mb-10 leading-relaxed">
              HeshbonAI משתלב בדרך שבה המשרד שלכם כבר עובד. הוא ממכן מעקבים חוזרים, אוסף מסמכים דרך וואטסאפ, ונותן לצוות שלכם שקיפות במקום אחד.
            </p>

            <div class="flex flex-col sm:flex-row items-start gap-4 mb-10">
              <a href="/he/contact" class="btn-primary text-base px-8 py-4">
                התחילו עכשיו
              </a>
              <a href="/he/pricing" class="btn-secondary text-base px-8 py-4">
                ראו מחירים
              </a>
            </div>

            <div class="flex flex-wrap items-center justify-start gap-4 text-muted text-sm">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                בנוי למשרדי רו״ח בישראל
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-whatsapp" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                WhatsApp-native
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                עברית-first
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                בלי פורטל ללקוח
              </div>
            </div>
          </div>

          <div class="relative">
            <div class="card shadow-2xl shadow-blue/5">
              <div class="flex items-center justify-between mb-6">
                <div>
                  <h3 class="text-white font-semibold text-sm">סקירת לקוחות</h3>
                  <p class="text-muted text-xs mt-0.5">מרץ 2026</p>
                </div>
                <div class="flex items-center gap-2">
                  <span class="px-2 py-1 bg-success/10 text-success text-xs font-medium rounded-md">12 הושלמו</span>
                  <span class="px-2 py-1 bg-warning/10 text-warning text-xs font-medium rounded-md">5 ממתינים</span>
                  <span class="px-2 py-1 bg-error/10 text-error text-xs font-medium rounded-md">2 באיחור</span>
                </div>
              </div>

              <div class="space-y-3">
                <div class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-success/10 flex items-center justify-center"><span class="text-success text-xs font-bold">אכ</span></div>
                    <div>
                      <p class="text-white text-sm font-medium">אבי כהן</p>
                      <p class="text-muted text-xs">3/3 מסמכים התקבלו</p>
                    </div>
                  </div>
                  <span class="px-2 py-0.5 bg-success/10 text-success text-xs rounded font-medium">הושלם</span>
                </div>

                <div id="hero-dana-row-he" class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border transition-all duration-500">
                  <div class="flex items-center gap-3">
                    <div id="hero-dana-avatar-he" class="w-8 h-8 rounded-full bg-blue/10 flex items-center justify-center transition-colors duration-500"><span id="hero-dana-initials-he" class="text-blue text-xs font-bold transition-colors duration-500">דל</span></div>
                    <div>
                      <p class="text-white text-sm font-medium">דנה לוי</p>
                      <p id="hero-dana-sub-he" class="text-muted text-xs transition-opacity duration-300">2/4 מסמכים, נשלח מעקב</p>
                    </div>
                  </div>
                  <span id="hero-dana-badge-he" class="px-2 py-0.5 bg-blue/10 text-blue text-xs rounded font-medium transition-all duration-500">בתהליך</span>
                </div>

                <div class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-warning/10 flex items-center justify-center"><span class="text-warning text-xs font-bold">מש</span></div>
                    <div>
                      <p class="text-white text-sm font-medium">משה שפירא</p>
                      <p class="text-muted text-xs">0/5 מסמכים, אין תגובה</p>
                    </div>
                  </div>
                  <span class="px-2 py-0.5 bg-warning/10 text-warning text-xs rounded font-medium">ממתין</span>
                </div>

                <div class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-error/10 flex items-center justify-center"><span class="text-error text-xs font-bold">רמ</span></div>
                    <div>
                      <p class="text-white text-sm font-medium">רחל מזרחי</p>
                      <p class="text-muted text-xs">1/3 מסמכים, דדליין מחר</p>
                    </div>
                  </div>
                  <span class="px-2 py-0.5 bg-error/10 text-error text-xs rounded font-medium">באיחור</span>
                </div>
              </div>

              <div class="flex items-center gap-2 mt-4 px-1">
                <span id="hero-pulse-he" class="w-2 h-2 rounded-full bg-muted transition-colors duration-500"></span>
                <p id="hero-timestamp-he" class="text-muted text-xs transition-opacity duration-300">עודכן לפני 5 דקות</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 sm:py-28 bg-navy-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">הבעיה</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">מה מאט את המשרד שלכם בכל חודש</h2>
          <p class="text-muted mt-4 max-w-2xl mx-auto">
            רוב העבודה שמשאירה את הצוות עד מאוחר היא לא חשבונאות, אלא כל האדמין שמסביב: לרדוף אחרי לקוחות, להזין נתונים מחדש, לענות על אותן שאלות, ולהילחץ לפני דדליינים.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">שעות שמתבזבזות על רדיפה אחרי לקוחות</h3>
            <p class="text-muted text-sm leading-relaxed">
              הצוות שולח תזכורות, בודק מי ענה, ושולח שוב. רואי חשבון מקצועיים מבזבזים זמן על אדמין במקום על עבודה מחייבת.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-warning/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">הזנת נתונים ידנית ממסמכים</h3>
            <p class="text-muted text-sm leading-relaxed">
              חשבוניות, קבלות, דפי בנק. הצוות שלכם מקליד נתונים מתוך PDF-ים ותמונות אל טבלאות ותוכנות הנהלת חשבונות, מסמך אחר מסמך.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">אותן שאלות, שוב ושוב</h3>
            <p class="text-muted text-sm leading-relaxed">
              &quot;קיבלתם את החשבונית?&quot; &quot;מתי הדדליין למע״מ?&quot; &quot;איזה מסמכים צריך?&quot; הצוות שלכם עונה על אותן שאלות כל שבוע.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-warning/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">דוחות נדחקים לסוף</h3>
            <p class="text-muted text-sm leading-relaxed">
              בניית סיכומים ודוחות סטטוס חשובה אבל אף פעם לא דחופה, עד שדדליין מגיע. ואז כולם מנסים להבין במהירות איפה הדברים עומדים.
            </p>
          </div>

          <div class="card md:col-span-2 lg:col-span-2">
            <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">עבודה שמפוזרת בין וואטסאפ, מייל, אקסל וזיכרון</h3>
            <p class="text-muted text-sm leading-relaxed">
              אין מקום אחד לראות מי שלח מה ומה עדיין חסר. דברים חשובים חיים בצ׳אטים, בתיבות מייל, בגיליונות, ובראש של מישהו. כשהוא לא נמצא, אף אחד לא יודע את הסטטוס.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="how-it-works-he" class="py-20 sm:py-28 bg-navy">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">איך זה עובד</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">לא צריך לשנות איך המשרד שלכם עובד</h2>
          <p class="text-muted mt-4 max-w-2xl mx-auto">
            HeshbonAI משתלב בתהליך הקיים. הלקוחות שלכם ממשיכים להשתמש בוואטסאפ. הצוות שלכם מקבל דשבורד. המעקב קורה אוטומטית.
          </p>
        </div>

        <div class="relative max-w-4xl mx-auto">
          <div class="hidden md:block absolute top-7 left-[10%] right-[10%] h-px bg-border">
            <div id="hiw-line-he" class="h-full bg-blue origin-right" style="transform: scaleX(0); transition: transform 1.5s ease-out;"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-4">
            <div class="hiw-step-he text-center opacity-0 translate-y-4" style="transition: opacity 0.5s ease-out, transform 0.5s ease-out;">
              <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center mx-auto mb-4 relative z-10">
                <span class="text-blue font-display font-bold text-xl">1</span>
              </div>
              <h3 class="text-white font-semibold text-sm mb-2">מגדירים מה צריך</h3>
              <p class="text-muted text-xs leading-relaxed">
                מגדירים את המסמכים הנדרשים לכל לקוח או קבוצה.
              </p>
            </div>

            <div class="hiw-step-he text-center opacity-0 translate-y-4" style="transition: opacity 0.5s ease-out 0.2s, transform 0.5s ease-out 0.2s;">
              <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center mx-auto mb-4 relative z-10">
                <span class="text-blue font-display font-bold text-xl">2</span>
              </div>
              <h3 class="text-white font-semibold text-sm mb-2">מעקב אוטומטי</h3>
              <p class="text-muted text-xs leading-relaxed">
                העוזר שולח הודעות ללקוחות בוואטסאפ ומבקש את מה שחסר.
              </p>
            </div>

