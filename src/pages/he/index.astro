          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              observer.disconnect();
              waDemoHe.querySelectorAll('.wa-msg-he').forEach((msg) => {
                const el = msg as HTMLElement;
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
              });
            }
          });
        }, { threshold: 0.2 });
        observer.observe(waDemoHe);
      }
