            <p class="text-muted text-sm">תזכורות חכמות שמגיעות בזמן הנכון</p>
          </div>

          <div class="card text-center">
            <div class="text-4xl sm:text-5xl font-extrabold text-success mb-2" data-count-text="10+ שעות">—</div>
            <p class="text-white font-semibold mb-1">נחסכות בשבוע</p>
            <p class="text-muted text-sm">לכל עובד — זמן שחוזר לעבודה אמיתית</p>
          </div>
        </div>
      </div>
    </section>

    <script>
      function animateCountUpHe(el: HTMLElement, target: number, suffix: string, duration: number) {
        const start = performance.now();
        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(eased * target);
          el.textContent = current + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      const roiGridHe = document.getElementById('roi-grid-he');
      if (roiGridHe) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              observer.disconnect();
              roiGridHe.querySelectorAll<HTMLElement>('[data-count-to]').forEach((el, i) => {
                const target = parseInt(el.dataset.countTo || '0', 10);
                const suffix = el.dataset.suffix || '';
                setTimeout(() => animateCountUpHe(el, target, suffix, 1200), i * 150);
              });
              roiGridHe.querySelectorAll<HTMLElement>('[data-count-text]').forEach((el) => {
                setTimeout(() => {
                  el.style.transition = 'opacity 0.3s';
                  el.style.opacity = '0';
                  setTimeout(() => {
                    el.textContent = el.dataset.countText || '';
                    el.style.opacity = '1';
                  }, 200);
                }, 3 * 150 + 400);
              });
            }
          });
        }, { threshold: 0.3 });
        observer.observe(roiGridHe);
      }
    </script>

