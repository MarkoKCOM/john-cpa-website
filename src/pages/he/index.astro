---
import LayoutHe from '../../layouts/LayoutHe.astro';
import NavbarHe from '../../components/NavbarHe.astro';
import FooterHe from '../../components/FooterHe.astro';
import '../../styles/global.css';
---

<LayoutHe
  title="HeshbonAI — אוטומציה למשרד רו״ח | איסוף מסמכים בוואטסאפ"
  description="אוטומציה למעקב אחרי לקוחות ואיסוף מסמכים דרך וואטסאפ. בנוי למשרדי רואי חשבון בישראל. משתלב בכלים שלכם."
>
  <NavbarHe />
  <main>

    <!-- Hero -->
    <section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 bg-navy overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.15] mb-6 text-white">
            הפסיקו לרדוף אחרי לקוחות.<br />
            <span class="text-blue">תנו ל-HeshbonAI לעשות את זה.</span>
          </h1>

          <p class="text-lg sm:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
            המערכת שולחת תזכורות אוטומטיות בוואטסאפ, אוספת מסמכים מהלקוחות, ומעדכנת את הצוות שלכם — בלי שתצטרכו לעקוב אחרי אף אחד.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
            <a href="https://cal.com/heshbonai/intro" target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-8 py-4">
              קבעו שיחת היכרות
            </a>
            <a href="/contact" class="btn-secondary text-base px-8 py-4">
              צרו קשר
            </a>
          </div>

          <div class="flex flex-wrap items-center justify-center gap-4 text-muted text-sm">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              בנוי למשרדי רו״ח בישראל
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-whatsapp" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              עובד דרך וואטסאפ
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              בעברית מלאה
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              בלי פורטל ללקוח
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pain Points -->
    <section class="py-20 sm:py-28 bg-navy-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">הבעיה</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">מה באמת מעכב את המשרד שלכם כל חודש</h2>
          <p class="text-muted mt-4 max-w-2xl mx-auto">
            רוב הזמן שנשרף במשרד הוא לא על הנהלת חשבונות — אלא על האדמיניסטרציה סביבה. רדיפה אחרי לקוחות, העתקת נתונים, ותשובות חוזרות לאותן שאלות.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">שעות מבוזבזות על רדיפה אחרי מסמכים</h3>
            <p class="text-muted text-sm leading-relaxed">
              הצוות שולח תזכורות, בודק מי ענה, שולח שוב. רואי חשבון מקצועיים מבזבזים את הזמן שלהם על מעקב במקום על עבודה מקצועית.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-warning/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">לקוחות לא עונים למיילים</h3>
            <p class="text-muted text-sm leading-relaxed">
              אימיילים נקברים בתיבה. לקוחות לא פותחים, לא קוראים, לא מגיבים. ואתם שולחים שוב ושוב בלי תוצאה.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">עבודה מפוזרת בין וואטסאפ, מייל ואקסל</h3>
            <p class="text-muted text-sm leading-relaxed">
              אין מקום אחד לראות מי שלח מה ומה עדיין חסר. מידע חי בצ׳אטים, באימייל, בטבלאות, ובראש של מישהו שהיום לא בעבודה.
            </p>
          </div>

          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">דוחות נדחים בגלל מסמכים חסרים</h3>
            <p class="text-muted text-sm leading-relaxed">
              הדד-ליין מתקרב, אבל חצי מהלקוחות עדיין לא שלחו את מה שצריך. הדוח נדחה, הלחץ עולה, והלקוח לא מבין למה.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 sm:py-28 bg-navy">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">איך זה עובד</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">חמישה צעדים — מאפס לשליטה מלאה</h2>
          <p class="text-muted mt-4 max-w-2xl mx-auto">
            התהליך פשוט. אתם מגדירים מה צריך — המערכת עושה את השאר.
          </p>
        </div>

        <div class="max-w-3xl mx-auto space-y-8">
          <!-- Step 1 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center">
              <span class="text-blue font-bold text-lg">1</span>
            </div>
            <div>
              <h3 class="text-white font-semibold text-lg mb-1">הגדירו מה כל לקוח צריך</h3>
              <p class="text-muted text-sm leading-relaxed">
                העלו רשימת לקוחות והגדירו איזה מסמכים כל אחד צריך להגיש — חשבוניות, דפי בנק, תלושי שכר, מה שצריך.
              </p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center">
              <span class="text-blue font-bold text-lg">2</span>
            </div>
            <div>
              <h3 class="text-white font-semibold text-lg mb-1">המערכת שולחת תזכורות אוטומטיות בוואטסאפ</h3>
              <p class="text-muted text-sm leading-relaxed">
                הלקוח מקבל הודעה ברורה בוואטסאפ — בעברית, בשפה שלו, עם רשימה מדויקת של מה שחסר.
              </p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center">
              <span class="text-blue font-bold text-lg">3</span>
            </div>
            <div>
              <h3 class="text-white font-semibold text-lg mb-1">הלקוח שולח מסמכים ישירות בוואטסאפ</h3>
              <p class="text-muted text-sm leading-relaxed">
                בלי לינקים, בלי פורטלים, בלי סיסמאות. הלקוח פשוט שולח תמונה או קובץ בצ׳אט — כמו שהוא כבר רגיל.
              </p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue/10 border border-blue/20 flex items-center justify-center">
              <span class="text-blue font-bold text-lg">4</span>
            </div>
            <div>
              <h3 class="text-white font-semibold text-lg mb-1">המערכת מאשרת ומסווגת אוטומטית</h3>
              <p class="text-muted text-sm leading-relaxed">
                כל מסמך שמגיע מזוהה, מסווג לתיקיית הלקוח, ומסומן כהתקבל. אם משהו לא ברור — המערכת שואלת את הלקוח.
              </p>
            </div>
          </div>

          <!-- Step 5 -->
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-success/10 border border-success/20 flex items-center justify-center">
              <svg class="w-6 h-6 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-semibold text-lg mb-1">סיכום יומי לצוות שלכם</h3>
              <p class="text-muted text-sm leading-relaxed">
                כל בוקר הצוות מקבל סטטוס מלא — מי השלים, מי חסר, מי צריך טיפול. בלי לשאול אף אחד.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Integrations Strip -->
    <section class="py-16 sm:py-20 bg-navy-light border-t border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <p class="section-label mb-4">אינטגרציות</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-white">משתלב בכלים שאתם כבר עובדים איתם</h2>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
          <!-- WhatsApp -->
          <div class="flex items-center gap-2 text-muted hover:text-whatsapp transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            <span class="text-sm font-medium">WhatsApp</span>
          </div>
          <!-- Google -->
          <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            <span class="text-sm font-medium">Google</span>
          </div>
          <!-- Excel -->
          <div class="flex items-center gap-2 text-muted hover:text-success transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM9.5 17L7 13.5 9.5 10h1.7L9 13.5 11.2 17H9.5zm5 0h-1.7L15 13.5 12.8 10h1.7L17 13.5 14.5 17zM13 9V3.5L18.5 9H13z"/></svg>
            <span class="text-sm font-medium">Excel</span>
          </div>
          <!-- Hashavshevet -->
          <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3v-6m-3 6v-1m6-9a2 2 0 012 2v10a2 2 0 01-2 2H9a2 2 0 01-2-2V9a2 2 0 012-2m0-2h6a2 2 0 012 2v0H7v0a2 2 0 012-2z" /></svg>
            <span class="text-sm font-medium">חשבשבת</span>
          </div>
          <!-- Priority -->
          <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            <span class="text-sm font-medium">Priority</span>
          </div>
          <!-- Rivhit -->
          <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span class="text-sm font-medium">רווחית</span>
          </div>
          <!-- Green Invoice -->
          <div class="flex items-center gap-2 text-muted hover:text-success transition-colors">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            <span class="text-sm font-medium">Green Invoice</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Outcomes / Stats -->
    <section class="py-20 sm:py-28 bg-navy">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="section-label mb-4">תוצאות</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white">המספרים מדברים בעד עצמם</h2>
          <p class="text-muted mt-4 max-w-2xl mx-auto">
            משרדים שעובדים עם HeshbonAI רואים שינוי כבר בחודש הראשון.
          </p>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="card text-center">
            <div class="text-4xl sm:text-5xl font-extrabold text-blue mb-2">70%</div>
            <p class="text-white font-semibold mb-1">פחות זמן על רדיפה</p>
            <p class="text-muted text-sm">המעקב רץ לבד — הצוות מתפנה לעבודה מקצועית</p>
          </div>

          <div class="card text-center">
            <div class="text-4xl sm:text-5xl font-extrabold text-blue mb-2">82%</div>
            <p class="text-white font-semibold mb-1">שיעור תגובה בוואטסאפ</p>
            <p class="text-muted text-sm">לקוחות עונים בוואטסאפ — כי שם הם כבר נמצאים</p>
          </div>

          <div class="card text-center">
            <div class="text-4xl sm:text-5xl font-extrabold text-blue mb-2">94%</div>
            <p class="text-white font-semibold mb-1">מסמכים בזמן</p>
            <p class="text-muted text-sm">תזכורות חכמות שמגיעות בזמן הנכון</p>
          </div>

          <div class="card text-center">
            <div class="text-4xl sm:text-5xl font-extrabold text-blue mb-2">10+</div>
            <p class="text-white font-semibold mb-1">שעות נחסכות בשבוע</p>
            <p class="text-muted text-sm">לכל עובד במשרד — זמן שחוזר לעבודה אמיתית</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-16 sm:py-20 bg-navy-light border-t border-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
          תנו לצוות שלכם להתמקד ברואי חשבון
        </h2>
        <p class="text-muted text-lg mb-10 max-w-xl mx-auto">
          HeshbonAI מטפל במעקב, באיסוף ובסטטוס — כדי שהצוות שלכם יוכל לעשות את מה שהוא יודע הכי טוב.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://cal.com/heshbonai/intro" target="_blank" rel="noopener noreferrer" class="btn-primary text-lg px-8 py-4">קבעו שיחת היכרות</a>
          <a href="/contact" class="btn-secondary text-lg px-8 py-4">צרו קשר</a>
        </div>
      </div>
    </section>

  </main>
  <FooterHe />
</LayoutHe>
