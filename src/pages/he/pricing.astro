  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toggles = document.querySelectorAll('#faq-list-he .faq-toggle');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const item = toggle.closest('.faq-item');
          if (!item) return;

          const content = item.querySelector('.faq-content') as HTMLElement | null;
          const icon = toggle.querySelector('.faq-icon') as HTMLElement | null;
          if (!content || !icon) return;

          const isOpen = !content.classList.contains('hidden');

          document.querySelectorAll('#faq-list-he .faq-item').forEach((otherItem) => {
            if (otherItem !== item) {
              const otherContent = otherItem.querySelector('.faq-content') as HTMLElement | null;
              const otherIcon = otherItem.querySelector('.faq-icon') as HTMLElement | null;
              const otherToggle = otherItem.querySelector('.faq-toggle');
              if (!otherContent || !otherIcon || !otherToggle) return;

              otherContent.classList.add('hidden');
              otherContent.style.maxHeight = '';
              otherIcon.style.transform = 'rotate(0deg)';
              otherToggle.setAttribute('aria-expanded', 'false');
            }
          });

          if (isOpen) {
            content.style.maxHeight = '';
            setTimeout(() => content.classList.add('hidden'), 200);
            icon.style.transform = 'rotate(0deg)';
            toggle.setAttribute('aria-expanded', 'false');
          } else {
            content.classList.remove('hidden');
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
            toggle.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  </script>

  <style>
    .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .faq-content:not(.hidden) { max-height: none; }
    .faq-icon { transition: transform 0.2s ease; }
  </style>
