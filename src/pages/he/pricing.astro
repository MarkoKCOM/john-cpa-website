---
import LayoutHe from '../../layouts/LayoutHe.astro';
import NavbarHe from '../../components/NavbarHe.astro';
import FooterHe from '../../components/FooterHe.astro';
import '../../styles/global.css';

const title = 'מחירים — HeshbonAI | העוזר החכם למשרדי רו״ח';
const description = 'מחירים חודשיים בשקלים. כל התוכניות כוללות איסוף מסמכים בוואטסאפ, מעקב אוטומטי, לוח בקרה ותמיכה בעברית.';
---

<LayoutHe title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "האם הלקוחות ידעו שהם מדברים עם עוזר?",
        "acceptedAnswer": { "@type": "Answer", "text": "הודעות יוצאות מהמספר הממותג שלכם בוואטסאפ עם שם המשרד והלוגו. הטון מקצועי ואנושי. רוב הלקוחות חושבים שזה עובד חדש בצוות." }
      },
      {
        "@type": "Question",
        "name": "האם זה עובד בעברית?",
        "acceptedAnswer": { "@type": "Answer", "text": "כן. HeshbonAI הוא עברית-first. תומך גם באנגלית, ערבית ורוסית." }
      },
      {
        "@type": "Question",
        "name": "האם לקוחות צריכים פורטל?",
        "acceptedAnswer": { "@type": "Answer", "text": "לא. אפס הורדות, אפס הרשמות. לקוחות עונים בוואטסאפ — האפליקציה שהם כבר משתמשים בה כל יום." }
      },
      {
        "@type": "Question",
        "name": "כמה זמן לוקח ההקמה?",
        "acceptedAnswer": { "@type": "Answer", "text": "כל משרד מקבל הטמעה מודרכת. אנחנו קובעים שיחת הקמה, מייבאים את רשימת הלקוחות, מחברים את הוואטסאפ ומגדירים הכל יחד. רוב המשרדים עולים לאוויר תוך כמה ימים." }
      },
      {
        "@type": "Question",
        "name": "האם הצוות יכול לבדוק הודעות לפני שליחה?",
        "acceptedAnswer": { "@type": "Answer", "text": "כן. אתם שולטים בתבניות ובתזמון. הצוות יכול לבדוק, לעצור או לדרוס כל שיחה בכל רגע." }
      }
    ]
  })} />

  <NavbarHe />

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-4 bg-navy">
      <div class="max-w-4xl mx-auto text-center">
        <span class="section-label">מחירים</span>
        <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white">
          תוכניות פשוטות, מחירים בשקלים
        </h1>
        <p class="mt-6 text-lg md:text-xl text-muted max-w-2xl mx-auto">
          בלי הפתעות. בלי עמלות נסתרות. תשלום חודשי, ביטול בכל זמן.
        </p>
      </div>
    </section>

    <!-- Pricing Tiers -->
    <section class="pb-20 px-4 bg-navy-light pt-16">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start">

        <!-- Starter -->
        <div class="card flex flex-col h-full">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">Starter</h3>
            <p class="text-sm text-muted mt-1">עד 25 לקוחות</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white font-display">&#8362;1,000</span>
              <span class="text-muted text-sm">/חודש</span>
            </div>
          </div>
          <a href="https://cal.com/heshbonai/intro" target="_blank" rel="noopener noreferrer" class="btn-secondary w-full text-center mb-4">קבעו שיחת היכרות</a>
          <p class="text-xs text-muted/50 mb-8">*דמי הקמה עשויים לחול</p>
          <ul class="space-y-3 text-sm text-muted flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>מעקב אוטומטי ללא הגבלה</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>איסוף מסמכים בוואטסאפ</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>סיווג מסמכים עם AI</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>לוח בקרה וסיכומים יומיים</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>כל האינטגרציות כלולות (וואטסאפ, מייל, Google, Excel)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>תמיכה בעברית ואנגלית</li>
          </ul>
        </div>

        <!-- Professional -->
        <div class="bg-blue rounded-2xl p-8 flex flex-col h-full text-white ring-2 ring-blue shadow-xl shadow-blue/10 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-warning text-navy text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">הכי פופולרי</span>
          </div>
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">Professional</h3>
            <p class="text-sm text-white/70 mt-1">עד 100 לקוחות</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white font-display">&#8362;1,800</span>
              <span class="text-white/70 text-sm">/חודש</span>
            </div>
          </div>
          <a href="https://cal.com/heshbonai/intro" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 bg-white text-blue font-semibold rounded-lg hover:bg-blue-pale transition-all duration-200 text-sm shadow-sm w-full text-center mb-8">קבעו שיחת היכרות</a>
          <p class="text-xs text-white/60 mb-4">הכל ב-Starter, ובנוסף:</p>
          <ul class="space-y-3 text-sm text-white/90 flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>תמיכה רב-לשונית (רוסית, ערבית, צרפתית)</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>תזכורות מותאמות אישית</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>חיבור לחשבשבת, Priority, רווחית</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue-pale shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>תמיכה מועדפת</li>
          </ul>
        </div>

        <!-- Complete -->
        <div class="card flex flex-col h-full">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white">Complete</h3>
            <p class="text-sm text-muted mt-1">לקוחות ללא הגבלה</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-white font-display">&#8362;2,700</span>
              <span class="text-muted text-sm">/חודש</span>
            </div>
          </div>
          <a href="/he/contact" class="btn-secondary w-full text-center mb-8">צרו קשר</a>
          <p class="text-xs text-muted/60 mb-4">הכל ב-Professional, ובנוסף:</p>
          <ul class="space-y-3 text-sm text-muted flex-1">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>לקוחות ללא הגבלה</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>שרת ייעודי</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>חיבור API מותאם</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>מנהל הצלחה ייעודי</li>
          </ul>
        </div>
      </div>

      <p class="text-center text-muted text-sm mt-8 max-w-xl mx-auto">
        דמי הקמה עשויים לחול. תשלום שנתי — <strong class="text-white">חודשיים חינם</strong>. כל המחירים לא כוללים מע״מ.
      </p>
    </section>

    <!-- FAQ -->
    <section class="py-20 px-4 bg-navy">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="section-label">שאלות נפוצות</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-bold text-white">שאלות נפוצות</h2>
        </div>

        <div class="space-y-3" id="faq-list-he">
          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">האם הלקוחות ידעו שהם מדברים עם עוזר?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">הודעות יוצאות מהמספר הממותג שלכם בוואטסאפ עם שם המשרד והלוגו. הטון מקצועי ואנושי. רוב הלקוחות חושבים שזה עובד חדש בצוות. אם לקוח שואל משהו שהעוזר לא יודע לענות עליו — הוא מעביר את זה לצוות שלכם.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">האם זה עובד בעברית?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">כן. HeshbonAI הוא עברית-first. תומך גם באנגלית, ערבית ורוסית.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">האם הצוות יכול לבדוק הודעות?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">כן. אתם שולטים בתבניות ההודעות ובתזמון המעקב. הצוות יכול לבדוק, לעצור או לדרוס כל שיחה בכל רגע. יש תיעוד מלא של כל הודעה שנשלחה.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">מה אם לקוח שואל משהו מורכב?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">העוזר מעביר את השאלה לצוות שלכם מיד במקום לנחש. הוא עונה ללקוח: ״שאלה טובה — בודק עם הצוות וחוזר אליך.״ ומסמן את זה בלוח הבקרה.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">אפשר לשלוט בתזמון התזכורות?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">כן. אתם קובעים את לוח הזמנים של התזכורות (מינימום 3 ימים בין הודעות). העוזר אף פעם לא שולח לפני 08:00 או אחרי 20:00. הוא מכבד שבת וחגים אוטומטית.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">האם לקוחות צריכים פורטל או אפליקציה?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">לא. אפס הורדות. אפס הרשמות. הלקוחות עונים בוואטסאפ — האפליקציה שהם כבר משתמשים בה כל יום. פשוט שולחים תמונה או קובץ.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">כמה זמן לוקח ההקמה?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">כל משרד מקבל הטמעה מודרכת. אנחנו קובעים שיחת הקמה, מייבאים את רשימת הלקוחות, מחברים את הוואטסאפ ומגדירים הכל יחד. רוב המשרדים עולים לאוויר תוך כמה ימים.</p>
            </div>
          </div>

          <div class="faq-item rounded-2xl border border-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-right hover:bg-navy-light transition-colors" aria-expanded="false">
              <span class="font-medium text-white">האם צריך WhatsApp Business?</span>
              <svg class="faq-icon w-5 h-5 text-muted shrink-0 mr-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-muted text-sm leading-relaxed">כן. HeshbonAI משתמש ב-API הרשמי של WhatsApp Business. אנחנו מלווים אתכם בהקמה אם עוד אין לכם — רוב המשרדים מסיימים את זה תוך יום.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Billing -->
    <section class="py-12 px-4 bg-navy-light border-t border-border">
      <div class="max-w-3xl mx-auto text-center text-xs text-muted/60 space-y-1">
        <p>כל המחירים בשקלים, לא כולל מע״מ (17%).</p>
        <p>תשלום חודשי כברירת מחדל, שנתי בהנחה של 17%.</p>
        <p>תשלום בכרטיס אשראי או העברה בנקאית. חשבונית מס תסופק.</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-4 bg-navy border-t border-border">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          תנו לצוות שלכם להתמקד בחשבונאות
        </h2>
        <p class="mt-6 text-muted text-lg max-w-xl mx-auto">
          HeshbonAI מטפל במעקב. הצוות שלכם מטפל בחשבונאות.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://cal.com/heshbonai/intro" target="_blank" rel="noopener noreferrer" class="btn-primary text-lg px-8 py-4">קבעו שיחת היכרות</a>
          <a href="/he/contact" class="btn-secondary text-lg px-8 py-4">שלחו הודעה</a>
        </div>
      </div>
    </section>
  </main>

  <FooterHe />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const toggles = document.querySelectorAll('#faq-list-he .faq-toggle');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const item = toggle.closest('.faq-item');
          const content = item.querySelector('.faq-content');
          const icon = toggle.querySelector('.faq-icon');
          const isOpen = !content.classList.contains('hidden');

          document.querySelectorAll('#faq-list-he .faq-item').forEach((otherItem) => {
            if (otherItem !== item) {
              otherItem.querySelector('.faq-content').classList.add('hidden');
              otherItem.querySelector('.faq-content').style.maxHeight = null;
              otherItem.querySelector('.faq-icon').style.transform = 'rotate(0deg)';
              otherItem.querySelector('.faq-toggle').setAttribute('aria-expanded', 'false');
            }
          });

          if (isOpen) {
            content.style.maxHeight = null;
            setTimeout(() => content.classList.add('hidden'), 200);
            icon.style.transform = 'rotate(0deg)';
            toggle.setAttribute('aria-expanded', 'false');
          } else {
            content.classList.remove('hidden');
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(180deg)';
            toggle.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  </script>

  <style>
    .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .faq-content:not(.hidden) { max-height: none; }
    .faq-icon { transition: transform 0.2s ease; }
  </style>
</LayoutHe>
