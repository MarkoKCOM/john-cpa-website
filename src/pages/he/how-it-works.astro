---
import FooterHe from '../../components/FooterHe.astro';
import NavbarHe from '../../components/NavbarHe.astro';
import LayoutHe from '../../layouts/LayoutHe.astro';
import '../../styles/global.css';
---

<LayoutHe
  title="איך HeshbonAI עובד - איסוף מסמכים אוטומטי בוואטסאפ"
  description="ראו איך HeshbonAI מייעל מעקב אחרי לקוחות ואיסוף מסמכים בוואטסאפ ב-5 צעדים. הגדרה, מעקב אוטומטי, קבלה, סיווג עם AI ומעקב יומי."
  breadcrumbs={[
    { name: "דף הבית", url: "https://heshbonai.co/he/" },
    { name: "איך זה עובד", url: "https://heshbonai.co/he/how-it-works/" }
  ]}
>
  <NavbarHe />

  <main class="pt-24" dir="rtl">
    <section class="py-20 md:py-28 bg-navy pt-32 pb-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="section-label mb-4">איך זה עובד</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white">
          חמישה צעדים לאפס רדיפות.
        </h1>
        <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto">
          הגדירו מה צריך. HeshbonAI מטפל בכל המעקב. הצוות שלכם מקבל שקיפות מלאה.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-navy-light">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="space-y-16 md:space-y-24">
          <!-- שלב 1 - הגדרה -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">1</div>
                <p class="section-label">הגדרה</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">הגדירו מה כל לקוח צריך</h2>
              <p class="text-muted text-lg mb-6">
                ייבוא רשימת לקוחות, הקצאת מסמכים נדרשים, הגדרת דדליינים. CSV או חיבור לתוכנת חשבונאות. הכל מונחה בהטמעה.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">ייבוא CSV או חיבור לתוכנה</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">חשבשבת / Priority / רווחית</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">הטמעה מודרכת</span>
                </li>
              </ul>
            </div>
            <div class="card text-center">
              <svg class="w-20 h-20 mx-auto text-blue/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
              </svg>
              <p class="text-muted mt-4">העלאת CSV או חיבור לתוכנת החשבונאות שלכם</p>
            </div>
          </div>

          <!-- שלב 2 - אוטומציה -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">2</div>
                <p class="section-label">אוטומציה</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">העוזר עוקב אוטומטית</h2>
              <p class="text-muted text-lg mb-6">
                HeshbonAI שולח הודעות מהמספר הממותג שלכם בוואטסאפ. תזמון חכם, מכבד שבת וחגים. מעביר לצוות כשצריך. רואי חשבון יכולים גם לשלוח הודעות לעוזר.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">תזמון חכם עם שעות שקט ושבת</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">מעביר לצוות רק כשצריך</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">רואי חשבון יכולים לבדוק סטטוס</span>
                </li>
              </ul>
            </div>
            <div class="md:order-1">
              <div class="rounded-2xl overflow-hidden border border-border shadow-lg max-w-sm mx-auto" dir="ltr">
                <div class="bg-[#075E54] px-4 py-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-white text-xs font-bold">אכ</div>
                  <div>
                    <p class="text-white text-sm font-semibold">אבי כהן</p>
                    <p class="text-white/60 text-xs">מחובר</p>
                  </div>
                </div>
                <div class="bg-[#0B141A] px-3 py-4 space-y-2" dir="rtl">
                  <div class="flex justify-end">
                    <div class="max-w-[85%] rounded-lg px-3 py-2 bg-[#1F2C34] text-[#E9EDEF]" style="border-top-right-radius: 2px;">
                      <p class="text-[#00A884] text-xs font-medium mb-1">John</p>
                      <p class="text-sm leading-relaxed">היי אבי, חסרים לנו 3 מסמכים לדוח השנתי שלך. אפשר לשלוח אותם לכאן?</p>
                      <div class="flex justify-start mt-1"><span class="text-[10px] text-[#8696A0]">10:02</span></div>
                    </div>
                  </div>
                  <div class="flex justify-start">
                    <div class="max-w-[85%] rounded-lg px-3 py-2 bg-[#005C4B] text-[#E9EDEF]" style="border-top-left-radius: 2px;">
                      <p class="text-sm">בטח, תן לי רגע למצוא אותם!</p>
                      <div class="flex justify-start mt-1"><span class="text-[10px] text-[#8696A0]">11:47</span></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- שלב 3 - קבלה -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">3</div>
                <p class="section-label">קבלה</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">הלקוח שולח מסמכים</h2>
              <p class="text-muted text-lg mb-6">
                הלקוח עונה בוואטסאפ עם תמונה או קובץ. בלי פורטל, בלי אפליקציה. העוזר מאשר קבלה מיד.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">תמונה או קובץ ישירות בוואטסאפ</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">בלי פורטל / אפליקציה / הרשמה</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">אישור קבלה מיידי</span>
                </li>
              </ul>
            </div>
            <div class="card text-center">
              <svg class="w-20 h-20 mx-auto text-blue/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <p class="text-muted mt-4">הלקוח שולח תמונה או קובץ בוואטסאפ - וזהו</p>
            </div>
          </div>

          <!-- שלב 4 - סיווג -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="md:order-2">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">4</div>
                <p class="section-label">סיווג</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">המערכת מאשרת ועוקבת</h2>
              <p class="text-muted text-lg mb-6">
                AI מסווג את המסמך, מעדכן סטטוס ומודיע לצוות. כל מסמך מותאם ללקוח ולבקשה אוטומטית.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">סיווג מסמכים עם AI</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">התאמה אוטומטית ללקוח</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">הצוות מקבל עדכון</span>
                </li>
              </ul>
            </div>
            <div class="md:order-1 card text-center">
              <svg class="w-20 h-20 mx-auto text-blue/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
              <p class="text-muted mt-4">AI מסווג ומתאים כל מסמך אוטומטית</p>
            </div>
          </div>

          <!-- שלב 5 - מעקב -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-full bg-blue text-white flex items-center justify-center font-display font-bold text-lg">5</div>
                <p class="section-label">מעקב</p>
              </div>
              <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">הצוות מקבל שקיפות יומית</h2>
              <p class="text-muted text-lg mb-6">
                לוח בקרה אחד שמראה מי שלח מה, מה חסר ומה דחוף. סיכומים יומיים ויצוא לתוכנת חשבונאות.
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">מעקב סטטוס בזמן אמת</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">סיכומים יומיים</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-blue mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-muted">יצוא בלחיצה לחשבשבת / Priority</span>
                </li>
              </ul>
            </div>
            <div class="card" dir="ltr">
              <div class="flex items-center justify-between mb-6">
                <h3 class="font-semibold text-white text-sm">סטטוס מסמכים</h3>
                <span class="text-xs text-muted">עודכן עכשיו</span>
              </div>
              <div class="space-y-4">
                <div>
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="text-offwhite">אבי כהן</span>
                    <span class="text-success font-mono text-xs">3/3 הושלם</span>
                  </div>
                  <div class="w-full bg-navy rounded-full h-1.5">
                    <div class="bg-success h-1.5 rounded-full" style="width: 100%"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="text-offwhite">דנה לוי</span>
                    <span class="text-blue font-mono text-xs">2/4 בתהליך</span>
                  </div>
                  <div class="w-full bg-navy rounded-full h-1.5">
                    <div class="bg-blue h-1.5 rounded-full" style="width: 50%"></div>
                  </div>
                </div>
                <div>
                  <div class="flex justify-between text-sm mb-1.5">
                    <span class="text-offwhite">משה שפירא</span>
                    <span class="text-warning font-mono text-xs">0/5 ממתין</span>
                  </div>
                  <div class="w-full bg-navy rounded-full h-1.5">
                    <div class="bg-warning h-1.5 rounded-full" style="width: 3%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 bg-navy border-t border-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          מוכנים לתת ל-HeshbonAI לטפל בזה?
        </h2>
        <p class="text-muted text-lg mb-8">
          הטמעה מודרכת. תוצאות כבר בשבוע הראשון.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://cal.com/heshbonai/intro" class="btn-primary text-lg px-8 py-4">קבעו שיחת היכרות</a>
          <a href="/he/contact" class="btn-secondary text-lg px-8 py-4">צרו קשר</a>
        </div>
      </div>
    </section>
  </main>

  <FooterHe />
</LayoutHe>
