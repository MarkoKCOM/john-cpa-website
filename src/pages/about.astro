---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="About JOHN — AI Document Collection for CPAs"
  description="JOHN is built in Israel for Israeli accountants. We automate document collection via WhatsApp so CPAs can focus on accounting, not chasing."
>
  <Navbar />

  <main class="pt-24">
    <!-- Hero -->
    <section class="py-20 md:py-28">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="section-label mb-4">About JOHN</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          We built the assistant<br />
          every CPA deserves
        </h1>
        <p class="text-lg md:text-xl text-cool-gray max-w-2xl mx-auto">
          JOHN was born from a simple observation: Israeli accountants spend more time chasing
          documents than doing actual accounting. We decided to fix that.
        </p>
      </div>
    </section>

    <!-- The Problem -->
    <section class="py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold mb-6">The problem we solve</h2>
            <p class="text-cool-gray text-lg mb-4">
              Every CPA firm in Israel has the same daily ritual: send WhatsApp messages to clients
              asking for documents. Follow up. Follow up again. Track what came in. Chase what didn't.
            </p>
            <p class="text-cool-gray text-lg mb-4">
              This eats <span class="text-off-white font-semibold">5-10 hours every week</span> per firm.
              It's tedious, repetitive, and keeps skilled accountants away from work that actually matters.
            </p>
            <p class="text-cool-gray text-lg">
              Client portals don't work because clients won't download another app.
              Email doesn't work because nobody reads email.
              But WhatsApp? <span class="text-off-white font-semibold">80%+ of Israelis use it daily.</span>
            </p>
          </div>
          <div class="card">
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-lg bg-coral/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-coral" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-off-white">250+ hours/year</p>
                  <p class="text-cool-gray text-sm">lost to document chasing per firm</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-lg bg-amber/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-off-white">23% email response rate</p>
                  <p class="text-cool-gray text-sm">vs 82% on WhatsApp</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-lg bg-electric/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-off-white">73% of portal uploads</p>
                  <p class="text-cool-gray text-sm">end up in the wrong folder</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Approach -->
    <section class="py-16 md:py-20 bg-charcoal/50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Our approach</h2>
          <p class="text-cool-gray text-lg max-w-2xl mx-auto">
            We don't ask clients to change their behavior. We meet them where they already are.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-whatsapp/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-whatsapp" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">WhatsApp-native</h3>
            <p class="text-cool-gray">No new apps, no portals, no passwords. Clients reply on the platform they use 50 times a day.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-electric/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">AI-powered</h3>
            <p class="text-cool-gray">JOHN understands context, deadlines, and urgency. It follows up intelligently, not robotically.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-mint/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-mint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-2">Built for Israel</h3>
            <p class="text-cool-gray">Hebrew-first. Respects Shabbat. Understands Israeli tax deadlines. Made by accountants, for accountants.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 md:py-28">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Ready to stop chasing?
        </h2>
        <p class="text-cool-gray text-lg mb-8">
          14 days free. No credit card. No setup fee.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#" class="btn-primary text-lg px-8 py-4">Start Your Free Trial</a>
          <a href="/pricing" class="btn-secondary text-lg px-8 py-4">See Pricing</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
