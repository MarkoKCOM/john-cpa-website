---
import AccessibilityWidget from '../components/AccessibilityWidget.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = 'https://heshbonai.co';
const currentUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const enUrl = currentUrl.replace('/he/', '/').replace('/he', '/');

const graphSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Heshbonai Ltd",
      "url": siteUrl,
      "logo": `${siteUrl}/images/logo%20tranparent.png`,
      "description": "עוזר AI למשרדי רואי חשבון - אוטומציה למעקב אחרי לקוחות, איסוף מסמכים ובקרת תהליכים דרך וואטסאפ.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "תל אביב",
        "addressCountry": "IL"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "support@heshbonai.co",
        "contactType": "customer support",
        "availableLanguage": ["Hebrew", "English"]
      }
    },
    {
      "@type": "WebSite",
      "name": "HeshbonAI - העוזר החכם למשרד רו״ח",
      "url": siteUrl,
      "description": "אוטומציה למעקב אחרי לקוחות, איסוף מסמכים ובקרת תהליכים דרך וואטסאפ.",
      "publisher": { "@id": `${siteUrl}/#organization` }
    },
    {
      "@type": "SoftwareApplication",
      "name": "HeshbonAI",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "עוזר AI שמייעל מעקב אחרי לקוחות, איסוף מסמכים ובקרת תהליכים למשרדי רואי חשבון דרך וואטסאפ.",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "1000",
        "highPrice": "2700",
        "priceCurrency": "ILS",
        "offerCount": "3"
      }
    }
  ]
};
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />

    <meta name="geo.region" content="IL" />
    <meta name="geo.placename" content="Tel Aviv" />
    <link rel="alternate" hreflang="he" href={currentUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />

    <link rel="icon" type="image/png" href="/images/logo%20tranparent.png" />
    <link rel="apple-touch-icon" href="/images/logo%20tranparent.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="HeshbonAI" />
    <meta property="og:locale" content="he_IL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(graphSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen">
    <a href="#main-content" class="skip-link">דלגו לתוכן הראשי</a>
    <slot />
    <AccessibilityWidget locale="he" />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const main = document.querySelector('main');
        if (!main) return;

        if (!main.id) main.id = 'main-content';
        if (!main.hasAttribute('tabindex')) main.setAttribute('tabindex', '-1');
      });
    </script>
  </body>
</html>
