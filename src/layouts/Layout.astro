---
import AccessibilityWidget from '../components/AccessibilityWidget.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const { title, description, canonical, breadcrumbs } = Astro.props;
const siteUrl = 'https://heshbonai.co';
const currentUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;

// Build page-specific hreflang: /about → /he/about, / → /he/
const pathname = Astro.url.pathname.replace(/\/$/, '') || '';
const heUrl = pathname === '' ? `${siteUrl}/he/` : `${siteUrl}/he${pathname}/`;

// Breadcrumb schema
const breadcrumbSchema = breadcrumbs?.length ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": item.url
  }))
} : null;

const graphSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Heshbonai Ltd",
      "url": siteUrl,
      "logo": `${siteUrl}/images/logo%20tranparent.png`,
      "description": "AI assistant for CPA firms - automates client follow-up, document collection, and workflow visibility through WhatsApp.",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "support@heshbonai.co",
        "contactType": "customer support",
        "availableLanguage": ["English", "Hebrew", "Spanish", "French", "Portuguese"]
      }
    },
    {
      "@type": "WebSite",
      "name": "HeshbonAI - The AI Assistant for CPA Firms",
      "url": siteUrl,
      "description": "Automate client follow-up, document collection, and status tracking through WhatsApp.",
      "publisher": { "@id": `${siteUrl}/#organization` }
    },
    {
      "@type": "SoftwareApplication",
      "name": "HeshbonAI",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "AI assistant that automates client follow-up, document collection, and workflow visibility for CPA firms through WhatsApp.",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "249",
        "highPrice": "699",
        "priceCurrency": "USD",
        "offerCount": "3"
      }
    }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />

    <link rel="alternate" hreflang="en" href={currentUrl} />
    <link rel="alternate" hreflang="he" href={heUrl} />
    <link rel="alternate" hreflang="x-default" href={currentUrl} />

    <link rel="icon" type="image/png" href="/images/logo%20tranparent.png" />
    <link rel="apple-touch-icon" href="/images/logo%20tranparent.png" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="HeshbonAI" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={`${siteUrl}/images/og-cover.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="HeshbonAI - AI Assistant for CPA Firms" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/images/og-cover.png`} />

    <script type="application/ld+json" set:html={JSON.stringify(graphSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
    <AccessibilityWidget locale="en" />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const main = document.querySelector('main');
        if (!main) return;

        if (!main.id) main.id = 'main-content';
        if (!main.hasAttribute('tabindex')) main.setAttribute('tabindex', '-1');
      });
    </script>
  </body>
</html>
