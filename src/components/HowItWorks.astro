---
---

<section id="how-it-works" class="py-20 sm:py-28 bg-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="section-label mb-4">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">You don't need to change how your firm works</h2>
      <p class="text-muted mt-4 max-w-2xl mx-auto">
        HeshbonAI fits into your existing workflow. Your clients keep using WhatsApp. Your team gets a dashboard. The follow-up happens automatically.
      </p>
    </div>

    <div class="relative max-w-4xl mx-auto">
      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-7 left-[10%] right-[10%] h-px bg-border">
        <div id="hiw-line" class="h-full bg-blue origin-left" style="transform: scaleX(0); transition: transform 1.5s ease-out;"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-4">
        <div class="hiw-step text-center opacity-0 translate-y-4" style="transition: opacity 0.5s ease-out, transform 0.5s ease-out;">
          <div class="inline-flex p-1 bg-navy rounded-[1.125rem] mx-auto mb-4 relative z-10">
            <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center">
              <span class="text-blue font-display font-bold text-xl">1</span>
            </div>
          </div>
          <h3 class="text-white font-semibold text-sm mb-2">Define what's needed</h3>
          <p class="text-muted text-xs leading-relaxed">
            Set the required documents for each client or group.
          </p>
        </div>

        <div class="hiw-step text-center opacity-0 translate-y-4" style="transition: opacity 0.5s ease-out 0.2s, transform 0.5s ease-out 0.2s;">
          <div class="inline-flex p-1 bg-navy rounded-[1.125rem] mx-auto mb-4 relative z-10">
            <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center">
              <span class="text-blue font-display font-bold text-xl">2</span>
            </div>
          </div>
          <h3 class="text-white font-semibold text-sm mb-2">Auto follow-up</h3>
          <p class="text-muted text-xs leading-relaxed">
            The assistant messages clients on WhatsApp and requests missing documents.
          </p>
        </div>

        <div class="hiw-step text-center opacity-0 translate-y-4" style="transition: opacity 0.5s ease-out 0.4s, transform 0.5s ease-out 0.4s;">
          <div class="inline-flex p-1 bg-navy rounded-[1.125rem] mx-auto mb-4 relative z-10">
            <div class="w-14 h-14 rounded-2xl bg-whatsapp/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-whatsapp" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            </div>
          </div>
          <h3 class="text-white font-semibold text-sm mb-2">Client sends docs</h3>
          <p class="text-muted text-xs leading-relaxed">
            Client replies on WhatsApp with a photo or file. No portal, no app.
          </p>
        </div>

        <div class="hiw-step text-center opacity-0 translate-y-4" style="transition: opacity 0.5s ease-out 0.6s, transform 0.5s ease-out 0.6s;">
          <div class="inline-flex p-1 bg-navy rounded-[1.125rem] mx-auto mb-4 relative z-10">
            <div class="w-14 h-14 rounded-2xl bg-success/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
          </div>
          <h3 class="text-white font-semibold text-sm mb-2">Confirmed & tracked</h3>
          <p class="text-muted text-xs leading-relaxed">
            System confirms receipt, updates status, and notifies your team.
          </p>
        </div>

        <div class="hiw-step text-center opacity-0 translate-y-4" style="transition: opacity 0.5s ease-out 0.8s, transform 0.5s ease-out 0.8s;">
          <div class="inline-flex p-1 bg-navy rounded-[1.125rem] mx-auto mb-4 relative z-10">
            <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            </div>
          </div>
          <h3 class="text-white font-semibold text-sm mb-2">Daily summary</h3>
          <p class="text-muted text-xs leading-relaxed">
            Your team gets a clear dashboard and daily status report.
          </p>
        </div>
      </div>
    </div>

    <!-- Core message -->
    <div class="mt-16 text-center max-w-3xl mx-auto">
      <p class="text-muted text-base leading-relaxed border-l-2 border-blue pl-6 text-left">
        You do not need to change how your firm and clients already work. HeshbonAI fits into your current workflow, automates the repetitive follow-up, and gives you visibility in one place.
      </p>
    </div>
  </div>
</section>

<script>
  const hiwSection = document.getElementById('how-it-works');
  if (hiwSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          observer.disconnect();
          hiwSection.querySelectorAll('.hiw-step').forEach((step) => {
            (step as HTMLElement).style.opacity = '1';
            (step as HTMLElement).style.transform = 'translateY(0)';
          });
          const line = document.getElementById('hiw-line');
          if (line) {
            setTimeout(() => { line.style.transform = 'scaleX(1)'; }, 200);
          }
        }
      });
    }, { threshold: 0.2 });
    observer.observe(hiwSection);
  }
</script>
