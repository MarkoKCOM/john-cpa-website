---
---

<section id="how-it-works" class="py-20 sm:py-28 bg-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="section-label mb-4">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Fits how your firm already works</h2>
      <p class="text-muted mt-4 max-w-2xl mx-auto">
        HeshbonAI follows up with clients through WhatsApp, collects documents, and keeps your team updated in one dashboard.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center mx-auto mb-5">
          <span class="text-blue font-display font-bold text-xl">1</span>
        </div>
        <h3 class="text-white font-semibold text-lg mb-3">Set what each client needs</h3>
        <p class="text-muted text-sm leading-relaxed">
          Upload your client list and assign required documents. CSV import, or connect your accounting software directly.
        </p>
      </div>

      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center mx-auto mb-5">
          <span class="text-blue font-display font-bold text-xl">2</span>
        </div>
        <h3 class="text-white font-semibold text-lg mb-3">HeshbonAI follows up automatically</h3>
        <p class="text-muted text-sm leading-relaxed">
          The assistant messages each client on WhatsApp, requests missing documents, confirms receipt, and follows up on a smart schedule.
        </p>
      </div>

      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-blue/10 flex items-center justify-center mx-auto mb-5">
          <span class="text-blue font-display font-bold text-xl">3</span>
        </div>
        <h3 class="text-white font-semibold text-lg mb-3">Your team tracks progress in real time</h3>
        <p class="text-muted text-sm leading-relaxed">
          One dashboard for everything: who sent what, who hasn't, what's overdue, and what needs your team's attention.
        </p>
      </div>
    </div>

    <!-- Connecting line -->
    <div class="hidden md:flex justify-center mt-2 mb-0">
      <div class="w-2/3 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
    </div>
  </div>
</section>
