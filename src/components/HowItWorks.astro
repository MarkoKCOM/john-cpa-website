---
const steps = [
  {
    number: '01',
    title: 'Connect',
    description: 'Upload your client list and connect your WhatsApp Business account. Setup takes less than 10 minutes.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`,
    detail: '10 minutes to set up',
  },
  {
    number: '02',
    title: 'JOHN Takes Over',
    description: 'JOHN messages each client, asks for specific documents, follows up autonomously, and categorizes everything that comes in.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
    detail: 'Fully autonomous',
  },
  {
    number: '03',
    title: 'Documents in Your Dashboard',
    description: 'Every document lands organized in your dashboard — categorized by client, type, and tax year. Ready for filing, exportable in one click.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>`,
    detail: 'Organized & exportable',
  },
];
---

<section id="how-it-works" class="py-20 sm:py-28 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 fade-in">
      <p class="section-label mb-4">How it works</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold">Three Steps. <span class="gradient-text">Zero Chasing.</span></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 relative">
      <!-- Connecting line (desktop only) -->
      <div class="hidden md:block absolute top-24 left-[20%] right-[20%] h-px bg-gradient-to-r from-electric/40 via-mint/40 to-electric/40" aria-hidden="true"></div>

      {steps.map((step) => (
        <div class="relative text-center fade-in">
          <!-- Step Number -->
          <div class="relative inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-charcoal border border-cool-gray/20 mb-6 group-hover:border-electric/30 transition-colors">
            <div class="text-electric" set:html={step.icon} />
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-electric text-white text-xs font-bold flex items-center justify-center">{step.number}</span>
          </div>

          <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
          <p class="text-cool-gray text-sm leading-relaxed mb-4 max-w-xs mx-auto">{step.description}</p>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-mint bg-mint/10 px-3 py-1 rounded-full">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            {step.detail}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
