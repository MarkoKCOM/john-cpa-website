---
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-navy/90 backdrop-blur-md border-b border-border transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center">
        <img
          src="/images/brandmark%20logo.png"
          alt="HeshbonAI"
          class="h-9 md:h-10 w-auto"
          loading="eager"
        />
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="/how-it-works" class="text-muted hover:text-white transition-colors duration-200 text-sm font-medium">How It Works</a>
        <a href="/pricing" class="text-muted hover:text-white transition-colors duration-200 text-sm font-medium">Pricing</a>
        <a href="/about" class="text-muted hover:text-white transition-colors duration-200 text-sm font-medium">About</a>
        <a href="/accessibility" class="text-muted hover:text-white transition-colors duration-200 text-sm font-medium">Accessibility</a>
        <a href="/he" id="lang-switch-desktop" class="text-muted hover:text-white transition-colors duration-200 text-sm font-medium hidden">עברית</a>
      </div>

      <div class="hidden md:block">
        <a href="/contact" class="btn-primary text-sm">Get Started</a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden text-offwhite p-2 rounded-lg hover:bg-navy-light transition-colors" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-navy/95 backdrop-blur-md">
    <div class="px-4 py-4 space-y-3">
      <a href="/how-it-works" class="block text-muted hover:text-white transition-colors text-sm font-medium py-2">How It Works</a>
      <a href="/pricing" class="block text-muted hover:text-white transition-colors text-sm font-medium py-2">Pricing</a>
      <a href="/about" class="block text-muted hover:text-white transition-colors text-sm font-medium py-2">About</a>
      <a href="/accessibility" class="block text-muted hover:text-white transition-colors text-sm font-medium py-2">Accessibility</a>
      <a href="/he" id="lang-switch-mobile" class="text-muted hover:text-white transition-colors text-sm font-medium py-2 hidden">עברית</a>
      <a href="/contact" class="btn-primary text-sm w-full text-center mt-2">Get Started</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Show Hebrew language switch only for visitors from Israel
  async function checkGeoForHebrew() {
    try {
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
      if (tz === 'Asia/Jerusalem' || tz === 'Asia/Tel_Aviv') {
        document.getElementById('lang-switch-desktop')?.classList.remove('hidden');
        document.getElementById('lang-switch-mobile')?.classList.remove('hidden');
        return;
      }
      const res = await fetch('https://ipapi.co/json/', { signal: AbortSignal.timeout(3000) });
      const data = await res.json();
      if (data.country_code === 'IL') {
        document.getElementById('lang-switch-desktop')?.classList.remove('hidden');
        document.getElementById('lang-switch-mobile')?.classList.remove('hidden');
      }
    } catch { /* silently hide Hebrew for non-IL visitors */ }
  }
  checkGeoForHebrew();

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
