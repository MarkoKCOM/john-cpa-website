---
const painPoints = [
  {
    quote: '"Did you send that receipt yet?"',
    description: 'You spend hours every week sending reminders, following up, and re-following up. Your clients mean well — they just forget.',
    stat: '5-10 hrs/week',
    statLabel: 'spent chasing documents',
    icon: `<svg class="w-8 h-8 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    quote: '"I uploaded it to the portal... I think?"',
    description: 'Client portals go unused. Emails get buried. Documents end up in the wrong folder — or nowhere at all.',
    stat: '73%',
    statLabel: 'of docs misfiled or lost',
    icon: `<svg class="w-8 h-8 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>`,
  },
  {
    quote: '"Tax filing is in 3 days..."',
    description: 'Deadline week is chaos. Half your clients still haven\'t sent their documents. You\'re working nights and weekends.',
    stat: '3 days',
    statLabel: 'before deadline panic hits',
    icon: `<svg class="w-8 h-8 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
  },
];
---

<section class="py-20 sm:py-28 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 fade-in">
      <p class="section-label mb-4">The problem</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold">Sound familiar?</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {painPoints.map((point) => (
        <div class="card hover:border-cool-gray/25 transition-all duration-300 fade-in group">
          <div class="mb-4" set:html={point.icon} />
          <h3 class="text-lg sm:text-xl font-bold text-white mb-3">{point.quote}</h3>
          <p class="text-cool-gray text-sm leading-relaxed mb-6">{point.description}</p>
          <div class="border-t border-cool-gray/10 pt-4">
            <span class="text-2xl font-bold gradient-text">{point.stat}</span>
            <p class="text-cool-gray text-xs mt-1">{point.statLabel}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
