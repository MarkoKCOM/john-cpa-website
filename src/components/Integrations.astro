---
---

<section id="integrations" class="py-20 sm:py-28 bg-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="section-label mb-4">Integrations</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">Works with the tools your firm already uses</h2>
      <p class="text-muted mt-4 max-w-2xl mx-auto">
        HeshbonAI fits into your current workflow. No migration, no new portals, no disruption. Your accountants can also message the assistant directly on WhatsApp to check status, request updates, or manage tasks on the go.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- WhatsApp -->
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-whatsapp/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-whatsapp" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">WhatsApp</h3>
        <p class="text-muted text-sm">Clients respond on the app they already use. Your accountants can also message the assistant to check on client status or trigger follow-ups.</p>
      </div>

      <!-- Email Inbox -->
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Email Inbox</h3>
        <p class="text-muted text-sm">Monitor incoming emails for documents and auto-match them to client requests.</p>
      </div>

      <!-- Google Workspace -->
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Google Workspace</h3>
        <p class="text-muted text-sm">Sync with Google Drive, Sheets, and Docs. Organize files, generate analytics, and track clients faster with your existing Google tools.</p>
      </div>

      <!-- Excel / CSV Export -->
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h4a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Excel / CSV Export</h3>
        <p class="text-muted text-sm">Export client data, document status, and reports to Excel or CSV anytime for your own analysis.</p>
      </div>

      <!-- Accounting Software -->
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3v-6m-3 6v-1m6-9a2 2 0 012 2v10a2 2 0 01-2 2H9a2 2 0 01-2-2V9a2 2 0 012-2m0-2h6a2 2 0 012 2v0H7v0a2 2 0 012-2z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Accounting Software</h3>
        <p class="text-muted text-sm">Connect to Hashavshevet, Priority, Rivhit, Green Invoice, and more.</p>
      </div>

      <!-- API Access -->
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">API Access</h3>
        <p class="text-muted text-sm">Full API for custom integrations with your existing systems.</p>
      </div>
    </div>

    <!-- Tool logos strip -->
    <div class="mt-12 pt-10 border-t border-border">
      <p class="text-muted/60 text-xs text-center uppercase tracking-wider mb-6">Connects with</p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 opacity-60">
        <!-- WhatsApp -->
        <div class="flex items-center gap-2 text-muted hover:text-whatsapp transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          <span class="text-sm font-medium">WhatsApp</span>
        </div>
        <!-- Google -->
        <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          <span class="text-sm font-medium">Google</span>
        </div>
        <!-- Excel -->
        <div class="flex items-center gap-2 text-muted hover:text-success transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM9.5 17L7 13.5 9.5 10h1.7L9 13.5 11.2 17H9.5zm5 0h-1.7L15 13.5 12.8 10h1.7L17 13.5 14.5 17zM13 9V3.5L18.5 9H13z"/></svg>
          <span class="text-sm font-medium">Excel</span>
        </div>
        <!-- Hashavshevet -->
        <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3v-6m-3 6v-1m6-9a2 2 0 012 2v10a2 2 0 01-2 2H9a2 2 0 01-2-2V9a2 2 0 012-2m0-2h6a2 2 0 012 2v0H7v0a2 2 0 012-2z" /></svg>
          <span class="text-sm font-medium">Hashavshevet</span>
        </div>
        <!-- Priority -->
        <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          <span class="text-sm font-medium">Priority</span>
        </div>
        <!-- Rivhit -->
        <div class="flex items-center gap-2 text-muted hover:text-blue transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          <span class="text-sm font-medium">Rivhit</span>
        </div>
        <!-- Green Invoice -->
        <div class="flex items-center gap-2 text-muted hover:text-success transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          <span class="text-sm font-medium">Green Invoice</span>
        </div>
      </div>
    </div>

    <p class="text-muted text-sm text-center mt-8">
      More integrations coming soon. Have a specific request? <a href="/contact" class="text-blue hover:text-blue/80 underline underline-offset-2">Let us know</a>.
    </p>
  </div>
</section>
