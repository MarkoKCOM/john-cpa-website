---
const links = {
  product: [
    { label: 'How It Works', href: '#how-it-works' },
    { label: 'Features', href: '#features' },
    { label: 'Pricing', href: '#pricing' },
    { label: 'Demo', href: '#demo' },
  ],
  company: [
    { label: 'About', href: '/about' },
    { label: 'Blog', href: '/blog' },
    { label: 'Careers', href: '/careers' },
    { label: 'Contact', href: '/contact' },
  ],
  legal: [
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Service', href: '/terms' },
    { label: 'GDPR', href: '/gdpr' },
    { label: 'Security', href: '/security' },
  ],
  connect: [
    { label: 'LinkedIn', href: '#' },
    { label: 'Twitter', href: '#' },
    { label: 'WhatsApp', href: '#' },
    { label: 'support@heshbonai.co', href: 'mailto:support@heshbonai.co' },
  ],
};
---

<footer class="border-t border-cool-gray/10 bg-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-white font-extrabold text-xl tracking-tight">JOHN</a>
        <p class="text-cool-gray text-sm mt-3 leading-relaxed">AI-powered document collection for CPAs and accountants.</p>
        <div class="flex items-center gap-2 mt-4">
          <span class="text-xs text-cool-gray bg-charcoal px-2.5 py-1 rounded-full border border-cool-gray/10">Made in Israel</span>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Product</h3>
        <ul class="space-y-2.5">
          {links.product.map((link) => (
            <li><a href={link.href} class="text-cool-gray text-sm hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Company</h3>
        <ul class="space-y-2.5">
          {links.company.map((link) => (
            <li><a href={link.href} class="text-cool-gray text-sm hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Legal</h3>
        <ul class="space-y-2.5">
          {links.legal.map((link) => (
            <li><a href={link.href} class="text-cool-gray text-sm hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Connect</h3>
        <ul class="space-y-2.5">
          {links.connect.map((link) => (
            <li><a href={link.href} class="text-cool-gray text-sm hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-cool-gray/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-cool-gray text-sm">&copy; 2026 JOHN. All rights reserved.</p>
      <p class="text-cool-gray/50 text-xs">Designed for CPAs who value their time.</p>
    </div>
  </div>
</footer>
