---
---

<section id="product" class="py-20 sm:py-28 bg-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="section-label mb-4">Product</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">One place to see what's in, what's missing, and what needs attention</h2>
      <p class="text-muted mt-4 max-w-2xl mx-auto">
        Stop relying on chats, spreadsheets, and memory. HeshbonAI gives your firm a clear operational view of client collection.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Client Queue</h3>
        <p class="text-muted text-sm">Who is missing what, who needs a reminder, who is blocked. All clients in one prioritized view.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Document Inbox</h3>
        <p class="text-muted text-sm">Received files, categorized uploads, recent activity. AI reads and classifies documents automatically.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Action Center</h3>
        <p class="text-muted text-sm">Urgent deadlines, low-response clients, cases needing human review. Know what needs attention now.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-whatsapp/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-whatsapp" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">WhatsApp-Native</h3>
        <p class="text-muted text-sm">Clients respond on the app they already use. No portals, no downloads, no new accounts.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Deadline Intelligence</h3>
        <p class="text-muted text-sm">Automatic urgency escalation as deadlines approach. Never miss a filing date because of a missing document.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Security & Control</h3>
        <p class="text-muted text-sm">End-to-end encryption, audit trail, firm-branded communication. Your team reviews messages before they go out.</p>
      </div>
    </div>
  </div>
</section>
