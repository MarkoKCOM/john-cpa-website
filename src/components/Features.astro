---
const features = [
  {
    title: 'Autonomous Follow-Ups',
    description: 'JOHN follows up on its own schedule. Polite, persistent, and never forgets. Clients respond because it feels human.',
    stat: '82% response rate',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  },
  {
    title: 'Deadline Intelligence',
    description: 'JOHN knows your filing deadlines and escalates urgency automatically as dates approach. No calendar juggling.',
    stat: null,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'Document Recognition',
    description: 'Send a photo of a receipt or a blurry 106 form — JOHN identifies the document type and files it correctly.',
    stat: null,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  },
  {
    title: 'Smart Scheduling',
    description: 'Messages go out during optimal hours (Sun-Thu, 10AM-1PM peak) when clients are most likely to respond.',
    stat: null,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Multi-Language',
    description: 'JOHN speaks Hebrew, English, Arabic, and Russian. It detects your client\'s preferred language automatically.',
    stat: null,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>`,
  },
  {
    title: 'CPA Dashboard',
    description: 'See every client\'s document status at a glance. Filter by missing docs, deadlines, or response rate. Export for filing.',
    stat: null,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zm10 0a1 1 0 011-1h4a1 1 0 011 1v6a1 1 0 01-1 1h-4a1 1 0 01-1-1v-6z"/></svg>`,
  },
];
---

<section class="py-20 sm:py-28 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 fade-in">
      <p class="section-label mb-4">Features</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold">Built for How CPAs <span class="gradient-text">Actually Work</span></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="card hover:border-electric/20 transition-all duration-300 fade-in">
          <div class="w-12 h-12 rounded-xl bg-electric/10 flex items-center justify-center text-electric mb-5" set:html={feature.icon} />
          <h3 class="text-lg font-bold text-white mb-2">{feature.title}</h3>
          <p class="text-cool-gray text-sm leading-relaxed">{feature.description}</p>
          {feature.stat && (
            <div class="mt-4 pt-4 border-t border-cool-gray/10">
              <span class="text-sm font-semibold gradient-text">{feature.stat}</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
