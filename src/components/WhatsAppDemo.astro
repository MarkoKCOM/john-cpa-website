---
---

<section class="py-20 sm:py-28 bg-navy-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="section-label mb-4">Client Experience</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">A better client experience, without more work for your staff</h2>
    </div>

    <div id="wa-demo" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- WhatsApp Thread -->
      <div class="card p-0 overflow-hidden">
        <div class="bg-[#075E54] px-4 py-3 flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-white text-xs font-bold">LA</div>
          <div>
            <p class="text-white text-sm font-semibold">Levi & Associates</p>
            <p class="text-white/60 text-xs">online</p>
          </div>
        </div>
        <div class="bg-[#0B141A] px-3 py-4 space-y-2">
          <div class="wa-msg flex justify-start opacity-0" style="transform: translateY(8px); transition: opacity 0.4s ease-out, transform 0.4s ease-out;">
            <div class="max-w-[85%] rounded-lg px-3 py-2 bg-[#1F2C34] text-[#E9EDEF]" style="border-top-left-radius: 2px;">
              <p class="text-[#00A884] text-xs font-medium mb-1">John</p>
              <p class="text-sm leading-relaxed">Hi Avi, we need 3 documents for your annual filing:<br/>1. Bank statement (Dec)<br/>2. Vehicle expense receipts<br/>3. Signed form 106</p>
              <div class="flex justify-end mt-1"><span class="text-[10px] text-[#8696A0]">10:02</span></div>
            </div>
          </div>
          <div class="wa-msg flex justify-end opacity-0" style="transform: translateY(8px); transition: opacity 0.4s ease-out 0.6s, transform 0.4s ease-out 0.6s;">
            <div class="max-w-[85%] rounded-lg px-3 py-2 bg-[#005C4B] text-[#E9EDEF]" style="border-top-right-radius: 2px;">
              <p class="text-sm">Here's the bank statement</p>
              <div class="flex items-center gap-2 mt-1 bg-[#024B3F] rounded px-2 py-1">
                <svg class="w-4 h-4 text-[#8696A0]" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"/></svg>
                <span class="text-xs text-[#8696A0]">bank-dec-2025.pdf</span>
              </div>
              <div class="flex justify-end mt-1"><span class="text-[10px] text-[#8696A0]">11:47</span></div>
            </div>
          </div>
          <div class="wa-msg flex justify-start opacity-0" style="transform: translateY(8px); transition: opacity 0.4s ease-out 1.2s, transform 0.4s ease-out 1.2s;">
            <div class="max-w-[85%] rounded-lg px-3 py-2 bg-[#1F2C34] text-[#E9EDEF]" style="border-top-left-radius: 2px;">
              <p class="text-[#00A884] text-xs font-medium mb-1">John</p>
              <p class="text-sm leading-relaxed">Got it — bank statement received. Still need:<br/>- Vehicle expense receipts<br/>- Signed form 106</p>
              <div class="flex justify-end mt-1"><span class="text-[10px] text-[#8696A0]">11:47</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- AI Detection Panel -->
      <div class="card">
        <h3 class="text-white font-semibold text-sm mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          AI-Detected Status
        </h3>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span id="wa-dot-1" class="w-2 h-2 rounded-full bg-warning transition-colors duration-500"></span>
              <span class="text-sm text-offwhite">Bank statement (Dec)</span>
            </div>
            <span id="wa-status-1" class="text-xs text-warning font-medium transition-all duration-500">Pending</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-warning"></span>
              <span class="text-sm text-offwhite">Vehicle expense receipts</span>
            </div>
            <span class="text-xs text-warning font-medium">Pending</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-warning"></span>
              <span class="text-sm text-offwhite">Signed form 106</span>
            </div>
            <span class="text-xs text-warning font-medium">Pending</span>
          </div>
        </div>
        <div class="mt-6 pt-4 border-t border-border">
          <p class="text-muted text-xs">Next follow-up scheduled:</p>
          <p class="text-white text-sm font-medium mt-1">March 10, 10:00 AM</p>
        </div>
      </div>

      <!-- Dashboard Update -->
      <div class="card">
        <h3 class="text-white font-semibold text-sm mb-4 flex items-center gap-2">
          <svg class="w-4 h-4 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          Dashboard Updated
        </h3>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1.5">
              <span class="text-offwhite">Avi Cohen</span>
              <span id="wa-dash-count" class="text-warning font-mono text-xs transition-colors duration-500">0/3</span>
            </div>
            <div class="w-full bg-navy rounded-full h-1.5">
              <div id="wa-dash-bar" class="bg-warning h-1.5 rounded-full transition-all duration-700 ease-out" style="width: 3%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1.5">
              <span class="text-offwhite">Dana Levi</span>
              <span class="text-success font-mono text-xs">4/4</span>
            </div>
            <div class="w-full bg-navy rounded-full h-1.5">
              <div class="bg-success h-1.5 rounded-full" style="width: 100%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1.5">
              <span class="text-offwhite">Moshe Shapira</span>
              <span class="text-warning font-mono text-xs">0/5</span>
            </div>
            <div class="w-full bg-navy rounded-full h-1.5">
              <div class="bg-warning h-1.5 rounded-full" style="width: 3%"></div>
            </div>
          </div>
        </div>
        <div class="mt-6 pt-4 border-t border-border">
          <div class="flex items-center gap-2">
            <span id="wa-dash-pulse" class="w-2 h-2 rounded-full bg-muted transition-colors duration-500"></span>
            <p id="wa-dash-time" class="text-muted text-xs transition-opacity duration-300">Waiting for updates...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // WhatsApp demo: messages appear sequentially, then status updates
  const waDemo = document.getElementById('wa-demo');
  if (waDemo) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          observer.disconnect();

          // Reveal WhatsApp messages
          waDemo.querySelectorAll('.wa-msg').forEach((msg) => {
            const el = msg as HTMLElement;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          });

          // After messages appear, update the AI status panel
          setTimeout(() => {
            const dot = document.getElementById('wa-dot-1');
            const status = document.getElementById('wa-status-1');
            if (dot && status) {
              dot.className = 'w-2 h-2 rounded-full bg-success transition-colors duration-500';
              status.className = 'text-xs text-success font-medium transition-all duration-500';
              status.textContent = 'Received';
            }
          }, 1800);

          // Then update the dashboard bar
          setTimeout(() => {
            const bar = document.getElementById('wa-dash-bar');
            const count = document.getElementById('wa-dash-count');
            const pulse = document.getElementById('wa-dash-pulse');
            const time = document.getElementById('wa-dash-time');
            if (bar && count) {
              bar.style.width = '33%';
              bar.className = 'bg-blue h-1.5 rounded-full transition-all duration-700 ease-out';
              count.textContent = '1/3';
              count.className = 'text-blue font-mono text-xs transition-colors duration-500';
            }
            if (pulse && time) {
              pulse.className = 'w-2 h-2 rounded-full bg-success animate-pulse transition-colors duration-500';
              time.style.opacity = '0';
              setTimeout(() => {
                time.textContent = 'Live — updated just now';
                time.className = 'text-success text-xs transition-opacity duration-300';
                time.style.opacity = '1';
              }, 200);
            }
          }, 2400);
        }
      });
    }, { threshold: 0.2 });
    observer.observe(waDemo);
  }
</script>
