---
const tiers = [
  {
    name: 'Starter',
    price: '$15',
    unit: '/client/mo',
    description: 'Perfect for small practices getting started',
    clients: 'Up to 50 clients',
    features: [
      'Autonomous WhatsApp follow-ups',
      'Document recognition & filing',
      'Basic dashboard',
      'Email support',
    ],
    highlighted: false,
  },
  {
    name: 'Growth',
    price: '$10',
    unit: '/client/mo',
    description: 'For growing firms that need more power',
    clients: '51-200 clients',
    features: [
      'Everything in Starter',
      'Deadline intelligence',
      'Multi-language support',
      'Priority support',
      'Custom templates',
    ],
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    unit: '',
    description: 'For large firms with complex needs',
    clients: '200+ clients',
    features: [
      'Everything in Growth',
      'Dedicated account manager',
      'API access',
      'Custom integrations',
      'SLA guarantee',
    ],
    highlighted: false,
  },
];
---

<section id="pricing" class="py-20 sm:py-28 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 fade-in">
      <p class="section-label mb-4">Pricing</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold">Simple Pricing. <span class="gradient-text">No Surprises.</span></h2>
      <p class="text-cool-gray mt-4">14 days free. No credit card required.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {tiers.map((tier) => (
        <div class={`card relative flex flex-col fade-in ${tier.highlighted ? 'border-electric/40 ring-1 ring-electric/20' : ''}`}>
          {tier.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-electric text-white text-xs font-bold px-3 py-1 rounded-full">Most Popular</span>
            </div>
          )}

          <div class="mb-6">
            <h3 class="text-lg font-bold text-white mb-1">{tier.name}</h3>
            <p class="text-cool-gray text-sm">{tier.description}</p>
          </div>

          <div class="mb-6">
            <span class="text-4xl font-extrabold text-white">{tier.price}</span>
            {tier.unit && <span class="text-cool-gray text-sm">{tier.unit}</span>}
            <p class="text-electric text-sm font-medium mt-1">{tier.clients}</p>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-off-white">
                <svg class="w-4 h-4 text-mint flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {feature}
              </li>
            ))}
          </ul>

          <a href="#cta" class={tier.highlighted ? 'btn-primary w-full text-center' : 'btn-secondary w-full text-center'}>
            {tier.price === 'Custom' ? 'Contact Sales' : 'Start Free Trial'}
          </a>
        </div>
      ))}
    </div>

    <div class="text-center mt-8 fade-in">
      <a href="/pricing" class="text-electric hover:text-electric/80 text-sm font-medium transition-colors inline-flex items-center gap-1">
        See Full Pricing Details
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
