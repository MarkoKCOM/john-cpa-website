---
interface Props {
  locale: 'en' | 'he';
}

const { locale } = Astro.props;
const isHebrew = locale === 'he';
const widgetId = isHebrew ? 'site-accessibility-widget-he' : 'site-accessibility-widget-en';
const panelId = `${widgetId}-panel`;
const titleId = `${widgetId}-title`;

const copy = isHebrew
  ? {
      button: 'נגישות',
      buttonLabel: 'פתחו כלי נגישות באתר',
      title: 'כלי נגישות',
      close: 'סגירה',
      textSize: 'גודל טקסט',
      decrease: 'A-',
      resetSize: 'איפוס',
      increase: 'A+',
      contrast: 'ניגודיות גבוהה',
      links: 'קו תחתון לקישורים',
      readable: 'פונט קריא',
      motion: 'הפחתת תנועה',
      resetAll: 'איפוס כל ההגדרות',
      statement: 'להצהרת הנגישות',
      statementHref: '/he/accessibility',
    }
  : {
      button: 'Accessibility',
      buttonLabel: 'Open site accessibility tools',
      title: 'Accessibility Tools',
      close: 'Close',
      textSize: 'Text size',
      decrease: 'A-',
      resetSize: 'Reset',
      increase: 'A+',
      contrast: 'High contrast',
      links: 'Underline links',
      readable: 'Readable font',
      motion: 'Reduce motion',
      resetAll: 'Reset all settings',
      statement: 'Accessibility statement',
      statementHref: '/accessibility',
    };
---

<div
  id={widgetId}
  class:list={[
    'accessibility-widget',
    isHebrew && 'accessibility-widget--rtl',
  ]}
  data-locale={locale}
>
  <button
    type="button"
    class="accessibility-fab"
    aria-expanded="false"
    aria-controls={panelId}
    aria-label={copy.buttonLabel}
  >
    <svg class="accessibility-fab__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="5" r="1.5" fill="currentColor" stroke="none"></circle>
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5v4.5m0 0l-4.5 1.5m4.5-1.5l4.5 1.5M10 22l2-6 2 6m-6-3h8"></path>
    </svg>
    <span class="accessibility-fab__label">{copy.button}</span>
  </button>

  <div
    id={panelId}
    class="accessibility-panel hidden"
    role="dialog"
    aria-modal="false"
    aria-labelledby={titleId}
  >
    <div class="accessibility-panel__header">
      <h2 id={titleId} class="accessibility-panel__title">{copy.title}</h2>
      <button type="button" class="accessibility-panel__close" data-close-panel>
        {copy.close}
      </button>
    </div>

    <div class="accessibility-panel__body">
      <div class="accessibility-panel__section">
        <p class="accessibility-panel__label">{copy.textSize}</p>
        <div class="accessibility-font-controls">
          <button type="button" class="accessibility-control-btn" data-action="decrease-font">
            {copy.decrease}
          </button>
          <button type="button" class="accessibility-control-btn" data-action="reset-font">
            {copy.resetSize}
          </button>
          <button type="button" class="accessibility-control-btn" data-action="increase-font">
            {copy.increase}
          </button>
        </div>
      </div>

      <label class="accessibility-toggle">
        <input type="checkbox" data-setting="contrast" />
        <span>{copy.contrast}</span>
      </label>

      <label class="accessibility-toggle">
        <input type="checkbox" data-setting="links" />
        <span>{copy.links}</span>
      </label>

      <label class="accessibility-toggle">
        <input type="checkbox" data-setting="readableFont" />
        <span>{copy.readable}</span>
      </label>

      <label class="accessibility-toggle">
        <input type="checkbox" data-setting="reducedMotion" />
        <span>{copy.motion}</span>
      </label>

      <div class="accessibility-panel__actions">
        <button type="button" class="accessibility-reset-btn" data-action="reset-all">
          {copy.resetAll}
        </button>
        <a href={copy.statementHref} class="accessibility-statement-link">
          {copy.statement}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const widgets = document.querySelectorAll<HTMLElement>('.accessibility-widget');
  const storageKey = 'heshbonai-accessibility-settings';
  const defaultSettings = {
    fontScale: 1,
    contrast: false,
    links: false,
    readableFont: false,
    reducedMotion: false,
  };

  function clampFontScale(scale: number) {
    return Math.min(1.3, Math.max(0.9, scale));
  }

  function readSettings() {
    try {
      const raw = localStorage.getItem(storageKey);
      if (!raw) return { ...defaultSettings };
      const parsed = JSON.parse(raw);
      return {
        fontScale: clampFontScale(Number(parsed.fontScale ?? defaultSettings.fontScale)),
        contrast: Boolean(parsed.contrast),
        links: Boolean(parsed.links),
        readableFont: Boolean(parsed.readableFont),
        reducedMotion: Boolean(parsed.reducedMotion),
      };
    } catch {
      return { ...defaultSettings };
    }
  }

  function saveSettings(settings: typeof defaultSettings) {
    try {
      const isDefault =
        settings.fontScale === defaultSettings.fontScale &&
        settings.contrast === defaultSettings.contrast &&
        settings.links === defaultSettings.links &&
        settings.readableFont === defaultSettings.readableFont &&
        settings.reducedMotion === defaultSettings.reducedMotion;

      if (isDefault) {
        localStorage.removeItem(storageKey);
        return;
      }

      localStorage.setItem(storageKey, JSON.stringify(settings));
    } catch {
      // Ignore storage write failures and keep the UI working for the session.
    }
  }

  function applySettings(settings: typeof defaultSettings) {
    const root = document.documentElement;
    if (settings.fontScale === defaultSettings.fontScale) {
      root.style.removeProperty('font-size');
    } else {
      root.style.fontSize = `${settings.fontScale * 100}%`;
    }
    root.toggleAttribute('data-a11y-contrast', settings.contrast);
    root.toggleAttribute('data-a11y-links', settings.links);
    root.toggleAttribute('data-a11y-readable-font', settings.readableFont);
    root.toggleAttribute('data-a11y-reduced-motion', settings.reducedMotion);
  }

  function syncWidgetUi(widget: HTMLElement, settings: typeof defaultSettings) {
    widget.querySelectorAll<HTMLInputElement>('input[data-setting]').forEach((input) => {
      const setting = input.dataset.setting as keyof typeof defaultSettings;
      if (setting === 'fontScale') return;
      input.checked = Boolean(settings[setting]);
    });
  }

  function closePanel(widget: HTMLElement) {
    const panel = widget.querySelector<HTMLElement>('.accessibility-panel');
    const trigger = widget.querySelector<HTMLButtonElement>('.accessibility-fab');
    if (!panel || !trigger) return;

    panel.classList.add('hidden');
    trigger.setAttribute('aria-expanded', 'false');
    trigger.focus();
  }

  widgets.forEach((widget) => {
    const trigger = widget.querySelector<HTMLButtonElement>('.accessibility-fab');
    const panel = widget.querySelector<HTMLElement>('.accessibility-panel');
    const closeButton = widget.querySelector<HTMLButtonElement>('[data-close-panel]');
    if (!trigger || !panel || !closeButton) return;

    let settings = readSettings();
    applySettings(settings);
    syncWidgetUi(widget, settings);

    trigger.addEventListener('click', () => {
      const isHidden = panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !isHidden);
      trigger.setAttribute('aria-expanded', String(isHidden));
      if (isHidden) {
        const firstFocusable = panel.querySelector<HTMLElement>('button, input, a');
        firstFocusable?.focus();
      }
    });

    closeButton.addEventListener('click', () => closePanel(widget));

    panel.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closePanel(widget);
      }
    });

    document.addEventListener('click', (event) => {
      if (!widget.contains(event.target as Node)) {
        panel.classList.add('hidden');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    widget.querySelectorAll<HTMLButtonElement>('[data-action]').forEach((button) => {
      button.addEventListener('click', () => {
        const action = button.dataset.action;

        if (action === 'increase-font') {
          settings.fontScale = clampFontScale(settings.fontScale + 0.1);
        }

        if (action === 'decrease-font') {
          settings.fontScale = clampFontScale(settings.fontScale - 0.1);
        }

        if (action === 'reset-font') {
          settings.fontScale = defaultSettings.fontScale;
        }

        if (action === 'reset-all') {
          settings = { ...defaultSettings };
        }

        applySettings(settings);
        saveSettings(settings);
        syncWidgetUi(widget, settings);
      });
    });

    widget.querySelectorAll<HTMLInputElement>('input[data-setting]').forEach((input) => {
      input.addEventListener('change', () => {
        const setting = input.dataset.setting as Exclude<keyof typeof defaultSettings, 'fontScale'>;
        settings = {
          ...settings,
          [setting]: input.checked,
        };

        applySettings(settings);
        saveSettings(settings);
      });
    });
  });
</script>
