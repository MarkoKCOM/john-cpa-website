---
---

<section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 bg-navy overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-6 text-white">
          The AI assistant<br />
          <span class="text-blue">for CPA firms</span>
        </h1>

        <p class="text-lg text-muted max-w-lg mb-10 leading-relaxed">
          Automate client follow-up, document collection, and status tracking through WhatsApp — so your team spends less time chasing and more time doing actual accounting.
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4 mb-10">
          <a href="/contact" class="btn-primary text-base px-8 py-4">
            Get Started
          </a>
          <a href="/pricing" class="btn-secondary text-base px-8 py-4">
            See Pricing
          </a>
        </div>

        <!-- Trust chips -->
        <div class="flex flex-wrap items-center gap-4 text-muted text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Built for Israeli CPA firms
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-whatsapp" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            WhatsApp-native
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Hebrew-first
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            No client portal required
          </div>
        </div>
      </div>

      <!-- Right: Product UI Mockup -->
      <div class="relative">
        <div class="card shadow-2xl shadow-blue/5">
          <!-- Dashboard Header -->
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="text-white font-semibold text-sm">Client Overview</h3>
              <p class="text-muted text-xs mt-0.5">March 2026</p>
            </div>
            <div class="flex items-center gap-2">
              <span class="px-2 py-1 bg-success/10 text-success text-xs font-medium rounded-md">12 complete</span>
              <span class="px-2 py-1 bg-warning/10 text-warning text-xs font-medium rounded-md">5 pending</span>
              <span class="px-2 py-1 bg-error/10 text-error text-xs font-medium rounded-md">2 overdue</span>
            </div>
          </div>

          <!-- Client rows -->
          <div class="space-y-3">
            <div class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-success/10 flex items-center justify-center"><span class="text-success text-xs font-bold">AC</span></div>
                <div>
                  <p class="text-white text-sm font-medium">Avi Cohen</p>
                  <p class="text-muted text-xs">3/3 documents received</p>
                </div>
              </div>
              <span class="px-2 py-0.5 bg-success/10 text-success text-xs rounded font-medium">Complete</span>
            </div>

            <div id="hero-dana-row" class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border transition-all duration-500">
              <div class="flex items-center gap-3">
                <div id="hero-dana-avatar" class="w-8 h-8 rounded-full bg-blue/10 flex items-center justify-center transition-colors duration-500"><span id="hero-dana-initials" class="text-blue text-xs font-bold transition-colors duration-500">DL</span></div>
                <div>
                  <p class="text-white text-sm font-medium">Dana Levi</p>
                  <p id="hero-dana-sub" class="text-muted text-xs transition-opacity duration-300">2/4 documents — follow-up sent</p>
                </div>
              </div>
              <span id="hero-dana-badge" class="px-2 py-0.5 bg-blue/10 text-blue text-xs rounded font-medium transition-all duration-500">In Progress</span>
            </div>

            <div class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-warning/10 flex items-center justify-center"><span class="text-warning text-xs font-bold">MS</span></div>
                <div>
                  <p class="text-white text-sm font-medium">Moshe Shapira</p>
                  <p class="text-muted text-xs">0/5 documents — no response</p>
                </div>
              </div>
              <span class="px-2 py-0.5 bg-warning/10 text-warning text-xs rounded font-medium">Pending</span>
            </div>

            <div class="flex items-center justify-between py-3 px-4 bg-navy rounded-lg border border-border">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-error/10 flex items-center justify-center"><span class="text-error text-xs font-bold">RM</span></div>
                <div>
                  <p class="text-white text-sm font-medium">Rachel Mizrahi</p>
                  <p class="text-muted text-xs">1/3 documents — deadline tomorrow</p>
                </div>
              </div>
              <span class="px-2 py-0.5 bg-error/10 text-error text-xs rounded font-medium">Overdue</span>
            </div>
          </div>

          <!-- Updated timestamp -->
          <div class="flex items-center gap-2 mt-4 px-1">
            <span id="hero-pulse" class="w-2 h-2 rounded-full bg-muted transition-colors duration-500"></span>
            <p id="hero-timestamp" class="text-muted text-xs transition-opacity duration-300">Updated 5 min ago</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Hero progress animation: Dana goes from 2/4 → 4/4
  function runHeroAnimation() {
    const row = document.getElementById('hero-dana-row');
    if (!row) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          observer.disconnect();
          setTimeout(animateDana, 2000);
        }
      });
    }, { threshold: 0.5 });

    observer.observe(row);
  }

  function animateDana() {
    const sub = document.getElementById('hero-dana-sub');
    const badge = document.getElementById('hero-dana-badge');
    const avatar = document.getElementById('hero-dana-avatar');
    const initials = document.getElementById('hero-dana-initials');
    const pulse = document.getElementById('hero-pulse');
    const timestamp = document.getElementById('hero-timestamp');
    if (!sub || !badge || !avatar || !initials || !pulse || !timestamp) return;

    // Step 1: Update subtitle
    sub.style.opacity = '0';
    setTimeout(() => {
      sub.textContent = '4/4 documents received';
      sub.style.opacity = '1';
    }, 300);

    // Step 2: Update badge
    setTimeout(() => {
      badge.className = 'px-2 py-0.5 bg-success/10 text-success text-xs rounded font-medium transition-all duration-500';
      badge.textContent = 'Complete';
    }, 400);

    // Step 3: Update avatar color
    setTimeout(() => {
      avatar.className = avatar.className.replace('bg-blue/10', 'bg-success/10');
      initials.className = initials.className.replace('text-blue', 'text-success');
    }, 400);

    // Step 4: Pulse the timestamp
    setTimeout(() => {
      pulse.className = 'w-2 h-2 rounded-full bg-success animate-pulse transition-colors duration-500';
      timestamp.style.opacity = '0';
      setTimeout(() => {
        timestamp.textContent = 'Updated just now';
        timestamp.className = 'text-success text-xs transition-opacity duration-300';
        timestamp.style.opacity = '1';
      }, 200);
    }, 600);
  }

  runHeroAnimation();
</script>
