<section class="py-20 sm:py-28 bg-navy-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="section-label mb-4">Outcomes</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">What changes when follow-up becomes automatic</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      <div class="card text-center">
        <div class="text-3xl font-bold text-blue font-display mb-2">70%</div>
        <p class="text-offwhite text-sm font-medium mb-1">Less time on chasing</p>
        <p class="text-muted text-xs">Automated reminders replace manual follow-up</p>
      </div>

      <div class="card text-center">
        <div class="text-3xl font-bold text-blue font-display mb-2">82%</div>
        <p class="text-offwhite text-sm font-medium mb-1">Client response rate</p>
        <p class="text-muted text-xs">WhatsApp vs 23% for email</p>
      </div>

      <div class="card text-center">
        <div class="text-3xl font-bold text-blue font-display mb-2">94%</div>
        <p class="text-offwhite text-sm font-medium mb-1">On-time collection</p>
        <p class="text-muted text-xs">Documents in before the deadline</p>
      </div>

      <div class="card text-center">
        <div class="text-3xl font-bold text-blue font-display mb-2">1 day</div>
        <p class="text-offwhite text-sm font-medium mb-1">Setup time</p>
        <p class="text-muted text-xs">Import clients, connect WhatsApp, go</p>
      </div>
    </div>
  </div>
</section>
