---
---

<section class="py-16 sm:py-20 bg-navy-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="section-label mb-4">Outcomes</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">What changes when follow-up becomes automatic</h2>
      <p class="text-muted mt-4 max-w-2xl mx-auto">
        Less chasing, fewer missed deadlines, more time for the work your clients actually pay for.
      </p>
    </div>

    <div id="roi-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      <div class="card text-center">
        <div class="text-3xl font-bold text-blue font-display mb-2" data-count-to="70" data-suffix="%">0%</div>
        <p class="text-offwhite text-sm font-medium mb-1">Less time chasing clients</p>
        <p class="text-muted text-xs">Automated reminders replace manual follow-up calls and messages</p>
      </div>

      <div class="card text-center">
        <div class="text-3xl font-bold text-blue font-display mb-2" data-count-to="82" data-suffix="%">0%</div>
        <p class="text-offwhite text-sm font-medium mb-1">Client response rate</p>
        <p class="text-muted text-xs">WhatsApp vs 23% for email - clients reply where they're comfortable</p>
      </div>

      <div class="card text-center">
        <div class="text-3xl font-bold text-blue font-display mb-2" data-count-to="94" data-suffix="%">0%</div>
        <p class="text-offwhite text-sm font-medium mb-1">On-time document collection</p>
        <p class="text-muted text-xs">Documents arrive before the deadline, not the night before filing</p>
      </div>

      <div class="card text-center">
        <div class="text-3xl font-bold text-success font-display mb-2" data-count-text="10+ hrs">-</div>
        <p class="text-offwhite text-sm font-medium mb-1">Saved per week</p>
        <p class="text-muted text-xs">Time your team gets back for real accounting work</p>
      </div>
    </div>
  </div>
</section>

<script>
  function animateCountUp(el: HTMLElement, target: number, suffix: string, duration: number) {
    const start = performance.now();
    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      el.textContent = current + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const roiGrid = document.getElementById('roi-grid');
  if (roiGrid) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          observer.disconnect();
          roiGrid.querySelectorAll<HTMLElement>('[data-count-to]').forEach((el, i) => {
            const target = parseInt(el.dataset.countTo || '0', 10);
            const suffix = el.dataset.suffix || '';
            setTimeout(() => animateCountUp(el, target, suffix, 1200), i * 150);
          });
          roiGrid.querySelectorAll<HTMLElement>('[data-count-text]').forEach((el) => {
            setTimeout(() => {
              el.style.transition = 'opacity 0.3s';
              el.style.opacity = '0';
              setTimeout(() => {
                el.textContent = el.dataset.countText || '';
                el.style.opacity = '1';
              }, 200);
            }, 3 * 150 + 400);
          });
        }
      });
    }, { threshold: 0.3 });
    observer.observe(roiGrid);
  }
</script>
