<section id="cta" class="py-20 sm:py-28 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy via-charcoal/50 to-navy pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-electric/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-in">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold mb-6">
      Stop Chasing. <span class="gradient-text">Start Closing.</span>
    </h2>
    <p class="text-lg sm:text-xl text-cool-gray mb-10 max-w-xl mx-auto leading-relaxed">
      Your clients already have WhatsApp open. JOHN meets them there.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#" class="btn-primary text-base px-8 py-4">
        Start Your 14-Day Free Trial
      </a>
      <a href="#" class="btn-secondary text-base px-8 py-4">
        Book a 15-Minute Demo
      </a>
    </div>

    <p class="text-cool-gray text-sm mt-6">No credit card required. Setup in under 10 minutes.</p>
  </div>
</section>
